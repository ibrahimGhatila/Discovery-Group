---
import { photos, type PhotoKey } from '~/lib/photos';

type Aspect = '16/9' | '4/5' | '1/1' | '3/2' | '21/9' | '5/4' | '5/7' | '3/4' | '2/3';

interface Props {
  src: PhotoKey;
  alt: string;
  aspect?: Aspect;
  class?: string;
  loading?: 'eager' | 'lazy';
  sizes?: string;
}

const {
  src,
  alt,
  aspect = '4/5',
  class: cls = '',
  loading = 'lazy',
  sizes = '(min-width: 1024px) 50vw, 100vw',
} = Astro.props;

const aspectClass: Record<Aspect, string> = {
  '16/9': 'aspect-[16/9]',
  '4/5': 'aspect-[4/5]',
  '1/1': 'aspect-square',
  '3/2': 'aspect-[3/2]',
  '21/9': 'aspect-[21/9]',
  '5/4': 'aspect-[5/4]',
  '5/7': 'aspect-[5/7]',
  '3/4': 'aspect-[3/4]',
  '2/3': 'aspect-[2/3]',
};

const url = photos[src];
---
<figure class:list={['relative overflow-hidden bg-[var(--color-paper-deep)]', aspectClass[aspect], cls]}>
  <img
    src={url}
    alt={alt}
    loading={loading}
    decoding="async"
    sizes={sizes}
    class="absolute inset-0 w-full h-full object-cover"
    style="object-position: center;"
  />
</figure>
