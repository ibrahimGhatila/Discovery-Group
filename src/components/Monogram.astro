---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 32 } = Astro.props;
---
{/* Discovery Group monogram — a cropped D with a slim center mark. */}
<svg viewBox="0 0 40 40" width={size} height={size} class={cls} fill="none" aria-hidden="true">
  <rect x="0.75" y="0.75" width="38.5" height="38.5" rx="20" stroke="currentColor" stroke-width="1.4"/>
  <path d="M14 12 L14 28 L20 28 C25 28 28 24.5 28 20 C28 15.5 25 12 20 12 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
  <circle cx="20" cy="20" r="1.6" fill="currentColor"/>
</svg>
