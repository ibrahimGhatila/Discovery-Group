---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 40 } = Astro.props;
---
{/* Sunrise / sun motif — matches the existing Discovery Group logo */}
<svg viewBox="0 0 48 48" width={size} height={size} class={cls} fill="none" aria-hidden="true">
  <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/>
  <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
    <path d="M24 16 L24 8"/>
    <path d="M30 18 L36 12"/>
    <path d="M32 24 L40 24"/>
    <path d="M30 30 L36 36"/>
    <path d="M18 18 L12 12"/>
    <path d="M16 24 L8 24"/>
    <path d="M18 30 L12 36"/>
  </g>
  <circle cx="24" cy="24" r="6" fill="currentColor"/>
</svg>
