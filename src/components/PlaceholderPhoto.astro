---
interface Props {
  caption: string;
  aspect?: '16/9' | '4/5' | '1/1' | '3/2' | '21/9';
  variant?: 'clay' | 'forest' | 'oro' | 'night';
  class?: string;
}

const { caption, aspect = '16/9', variant = 'clay', class: className = '' } = Astro.props;

const aspectClass = {
  '16/9': 'aspect-[16/9]',
  '4/5': 'aspect-[4/5]',
  '1/1': 'aspect-square',
  '3/2': 'aspect-[3/2]',
  '21/9': 'aspect-[21/9]',
}[aspect];

const variantStyle = {
  clay: '',
  forest: 'background: linear-gradient(135deg, color-mix(in srgb, var(--color-forest) 70%, var(--color-ink)) 0%, var(--color-forest) 100%);',
  oro: 'background: linear-gradient(135deg, var(--color-oro) 0%, var(--color-oro-deep) 100%);',
  night: 'background: linear-gradient(135deg, color-mix(in srgb, var(--color-night) 60%, var(--color-oro-deep)) 0%, var(--color-night) 100%);',
}[variant];
---
<figure
  class:list={['placeholder-photo w-full', aspectClass, className]}
  style={variantStyle}
  role="img"
  aria-label={`Placeholder: ${caption}`}
>
  <figcaption class="caption">
    <span aria-hidden="true">▢ </span>
    {caption}
  </figcaption>
</figure>
