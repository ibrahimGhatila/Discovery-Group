---
import PlaceholderPhoto from './PlaceholderPhoto.astro';

interface Props {
  name: string;
  region: string;
  district: string;
  commodity: string;
  elevation: string;
  photoCaption: string;
  href: string;
  placeholder?: boolean;
}

const { name, region, district, commodity, elevation, photoCaption, href, placeholder } = Astro.props;
---

<a href={href} class="group block focus:outline-none">
  <article class="flex flex-col gap-4">
    <div class="relative">
      <PlaceholderPhoto caption={photoCaption} aspect="4/5" variant="forest" class="transition-opacity group-hover:opacity-90" />
      {placeholder && (
        <span class="absolute top-3 left-3 px-2 py-1 bg-[var(--color-paper)] text-[var(--color-ink)] text-[0.625rem] tracking-wider uppercase">
          Placeholder
        </span>
      )}
    </div>
    <div>
      <p class="eyebrow mb-2">{commodity} · {district}</p>
      <h3 class="h3 group-hover:text-[var(--color-clay)] transition-colors">{name}</h3>
      <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{region} · {elevation}</p>
    </div>
  </article>
</a>
