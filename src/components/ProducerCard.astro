---
import Photo from './Photo.astro';
import type { PhotoKey } from '~/lib/photos';

interface Props {
  name: string;
  region: string;
  district: string;
  commodity: string;
  elevation: string;
  photoCaption: string;
  href: string;
  placeholder?: boolean;
  index: number;
}

const { name, region, district, commodity, elevation, photoCaption, href, placeholder } = Astro.props;

const photoByCommodity: Record<string, PhotoKey> = {
  'Arabica coffee': 'producerCoffee',
  'Robusta coffee': 'producerCoffee',
  'Cocoa': 'producerCocoa',
  'Vanilla': 'producerVanilla',
  "Bird's eye chilli": 'chilli',
  'Sesame': 'sesame',
};
---

<a href={href} class="group block focus:outline-none">
  <article class="flex flex-col gap-5">
    <div class="relative">
      <Photo src={photoByCommodity[commodity] || 'producerCoffee'} alt={photoCaption} aspect="4/5" class="transition-transform duration-500 group-hover:scale-[1.01]" />
      {placeholder && (
        <span class="absolute top-4 left-4 px-2.5 py-1 bg-[var(--color-paper)] text-[var(--color-ink)] text-[0.625rem] tracking-[0.18em] uppercase border border-[var(--color-line)]">
          Template
        </span>
      )}
    </div>
    <div class="flex flex-col gap-2.5">
      <p class="eyebrow">{commodity} · {district}</p>
      <h3 class="font-display text-2xl tracking-tight text-balance group-hover:text-[var(--color-clay)] transition-colors" style="font-family: var(--font-display); font-weight: 540; letter-spacing: -0.02em;">
        {name}
      </h3>
      <p class="text-sm text-[var(--color-ink-muted)] leading-snug">{region}<br/>{elevation}</p>
    </div>
  </article>
</a>
