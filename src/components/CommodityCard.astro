---
import Photo from './Photo.astro';
import type { PhotoKey } from '~/lib/photos';

interface Props {
  title: string;
  eyebrow: string;
  summary: string;
  href: string;
  regions: string[];
  certifications: string[];
  heroCaption: string;
  qualityMetricLabel?: string;
  qualityMetricValue?: string;
  photo: PhotoKey;
  index: number;
  /** kept for API compat with index page; ignored */
  illus?: string;
  tone?: string;
}

const {
  title, eyebrow, summary, href, regions, certifications,
  qualityMetricLabel, qualityMetricValue, photo, index,
} = Astro.props;

const reversed = index % 2 === 0;
---

<a href={href} class="group block focus:outline-none border-t border-[var(--color-line)]" aria-label={`Read full ${title} specification`}>
  <article class="grid lg:grid-cols-12 gap-x-10 gap-y-8 py-14 lg:py-20 items-center">
    <div class:list={['lg:col-span-5', reversed ? 'lg:order-2' : '']}>
      <Photo src={photo} alt={`${title} — ${eyebrow}`} aspect="4/5" class="transition-transform duration-500 group-hover:scale-[1.01]" />
    </div>

    <div class:list={['lg:col-span-7 flex flex-col gap-6', reversed ? 'lg:order-1' : '']}>
      <p class="eyebrow">{eyebrow}</p>

      <h3 class="display-lg group-hover:text-[var(--color-clay)] transition-colors text-balance">
        {title}
      </h3>

      <p class="text-[var(--color-ink-muted)] leading-relaxed max-w-2xl text-[1.0625rem]">{summary}</p>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-4 pt-5 border-t border-[var(--color-line-soft)] max-w-2xl">
        <div>
          <p class="eyebrow eyebrow-muted mb-1.5">Origin</p>
          <p class="text-sm leading-snug">{regions.slice(0, 2).join(' · ')}{regions.length > 2 ? ` + ${regions.length - 2}` : ''}</p>
        </div>
        {qualityMetricLabel && qualityMetricValue && (
          <div>
            <p class="eyebrow eyebrow-muted mb-1.5">{qualityMetricLabel}</p>
            <p class="font-display text-lg tracking-tight" style="font-family: var(--font-display); font-weight: 500;">{qualityMetricValue}</p>
          </div>
        )}
        <div>
          <p class="eyebrow eyebrow-muted mb-1.5">Certifications</p>
          <p class="text-sm">{certifications.slice(0, 2).join(' · ')}{certifications.length > 2 ? '...' : ''}</p>
        </div>
      </div>

      <p class="mt-3 inline-flex items-center gap-2 text-sm font-medium uppercase tracking-wider text-[var(--color-clay)]">
        Full specification
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
      </p>
    </div>
  </article>
</a>
