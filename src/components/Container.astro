---
interface Props {
  as?: string;
  narrow?: boolean;
  class?: string;
}
const { as: Tag = 'div', narrow = false, class: className = '' } = Astro.props;
const widthClass = narrow ? 'max-w-[var(--container-3xl)]' : 'max-w-[var(--container-7xl)]';
---
<Tag class:list={['mx-auto px-6 lg:px-10', widthClass, className]}>
  <slot />
</Tag>
