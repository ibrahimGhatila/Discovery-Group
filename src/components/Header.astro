---
import { corporateNav, orocafeNav } from '~/lib/site';
import Monogram from './Monogram.astro';

interface Props {
  brand: 'discovery' | 'orocafe';
}

const { brand } = Astro.props;
const nav = brand === 'orocafe' ? orocafeNav : corporateNav;
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-40 backdrop-blur-xl" style="background: color-mix(in srgb, var(--color-paper) 88%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--color-line) 60%, transparent);">
  <div class="mx-auto max-w-[var(--container-7xl)] px-6 lg:px-12">
    <div class="flex items-center justify-between gap-6 h-[72px]">

      <a href={brand === 'orocafe' ? '/orocafe' : '/'} class="flex items-center gap-3" aria-label={brand === 'orocafe' ? 'Orocafe home' : 'Discovery Group home'}>
        {brand === 'orocafe' ? (
          <span style="font-weight: 600; font-size: 1.375rem; letter-spacing: -0.02em; color: var(--color-oro);">Orocafe</span>
        ) : (
          <>
            <Monogram class="text-[var(--color-gold)]" size={34} />
            <div class="flex flex-col leading-tight">
              <span style="font-family: var(--font-display); font-weight: 400; font-size: 1.0625rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-forest);">Discovery</span>
              <span class="text-[0.625rem] uppercase mt-0.5" style="letter-spacing: 0.24em; color: var(--color-ink-muted); font-weight: 500;">Group · Uganda</span>
            </div>
          </>
        )}
      </a>

      <nav class="hidden lg:flex items-center gap-8" aria-label="Primary">
        {nav.map((item) => {
          const isActive = pathname === item.href || (item.href !== '/' && item.href !== '/orocafe' && pathname.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'text-xs uppercase tracking-[0.22em] transition-colors py-1 relative font-medium',
                isActive ? 'text-[var(--color-forest)]' : 'text-[var(--color-ink-muted)] hover:text-[var(--color-forest)]'
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
              {isActive && <span class="absolute left-0 right-0 -bottom-1 h-px bg-[var(--color-forest)]"></span>}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-3 lg:gap-4">
        <div class="hidden sm:flex items-center text-[0.625rem] tracking-[0.22em] uppercase font-medium">
          <a href="/"
            class:list={['px-2 py-1 transition-opacity',
              brand === 'discovery' ? 'text-[var(--color-forest)]' : 'text-[var(--color-ink-muted)] hover:opacity-70']}
            aria-current={brand === 'discovery' ? 'page' : undefined}
          >DG</a>
          <span class="text-[var(--color-line)]" aria-hidden="true">·</span>
          <a href="/orocafe"
            class:list={['px-2 py-1 transition-opacity',
              brand === 'orocafe' ? 'text-[var(--color-forest)]' : 'text-[var(--color-ink-muted)] hover:opacity-70']}
            aria-current={brand === 'orocafe' ? 'page' : undefined}
          >Orocafe</a>
        </div>

        {brand === 'discovery' && (
          <a href="/contact" class="hidden md:inline-flex btn btn-primary" style="padding: 0.625rem 1.25rem; min-height: 38px; font-size: 0.6875rem;">
            Inquire
          </a>
        )}

        <details class="lg:hidden relative">
          <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Open menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 6h18M3 12h18M3 18h18" />
            </svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 border border-[var(--color-line)] bg-[var(--color-paper-pure)] py-2 min-w-[16rem] shadow-2xl">
            {nav.map((item) => (
              <a href={item.href} class="block px-5 py-2.5 text-xs uppercase tracking-[0.22em] font-medium hover:bg-[var(--color-paper-warm)]">{item.label}</a>
            ))}
            <div class="border-t border-[var(--color-line-soft)] mt-2 pt-2">
              <a href="/" class="block px-5 py-2 text-[0.625rem] uppercase tracking-[0.22em] text-[var(--color-ink-muted)] hover:bg-[var(--color-paper-warm)]">Discovery Group</a>
              <a href="/orocafe" class="block px-5 py-2 text-[0.625rem] uppercase tracking-[0.22em] text-[var(--color-ink-muted)] hover:bg-[var(--color-paper-warm)]">Orocafe</a>
            </div>
          </div>
        </details>
      </div>
    </div>
  </div>
</header>
