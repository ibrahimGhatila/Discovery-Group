---
import Photo from './Photo.astro';
import type { PhotoKey } from '~/lib/photos';

interface Props {
  title: string;
  category: string;
  origin: string;
  flavourNotes: string[];
  sizes: string[];
  heroCaption: string;
  href: string;
  index: number;
}

const { title, category, origin, flavourNotes, sizes, href, index } = Astro.props;

const photoByCategory: Record<string, PhotoKey> = {
  'Whole bean': 'beansClose',
  'Ground': 'pourover',
  'Capsule': 'espresso',
  'Drip bag': 'pourover',
  'Premix': 'latte',
  'Tea': 'pourover',
  'Instant': 'latte',
};
const variants: PhotoKey[] = ['beansClose', 'espresso', 'pourover', 'latte', 'package'];
const photo = photoByCategory[category] || variants[index % variants.length];
---

<a href={href} class="group block focus:outline-none">
  <article class="flex flex-col gap-5">
    <Photo src={photo} alt={title} aspect="4/5" class="transition-transform duration-500 group-hover:scale-[1.01]" />

    <div class="flex flex-col gap-2.5">
      <p class="eyebrow" style="color: var(--color-oro);">{category}</p>
      <h3 class="text-2xl text-balance transition-colors group-hover:text-[var(--color-oro)]" style="font-family: var(--font-display); font-weight: 540; letter-spacing: -0.015em; line-height: 1.15;">
        {title}
      </h3>
      <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">{flavourNotes.slice(0, 3).join(' · ')}</p>
      <div class="flex items-baseline justify-between mt-2 pt-3 border-t" style="border-color: var(--color-line);">
        <p class="text-xs uppercase tracking-wider" style="color: var(--color-ink-muted);">{origin}</p>
        <p class="text-[0.6875rem] font-mono" style="color: var(--color-ink-muted);">{sizes[0]}</p>
      </div>
    </div>
  </article>
</a>
