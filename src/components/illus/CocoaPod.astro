---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 200 } = Astro.props;
---
<svg viewBox="0 0 200 240" width={size} fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
  <!-- stem coming from top -->
  <path d="M100 8 Q102 18 100 30" stroke-width="1.5"/>
  <!-- pod outline (ellipse with pointed tips) -->
  <path d="M100 30 Q60 50 58 130 Q60 200 100 220 Q140 200 142 130 Q140 50 100 30Z" fill="currentColor" fill-opacity="0.08"/>
  <path d="M100 30 Q60 50 58 130 Q60 200 100 220 Q140 200 142 130 Q140 50 100 30Z"/>
  <!-- ridges -->
  <path d="M100 30 Q98 130 100 220" stroke-width="0.9"/>
  <path d="M82 36 Q72 130 82 215" stroke-width="0.8"/>
  <path d="M118 36 Q128 130 118 215" stroke-width="0.8"/>
  <path d="M68 50 Q60 130 68 205" stroke-width="0.7"/>
  <path d="M132 50 Q140 130 132 205" stroke-width="0.7"/>
  <!-- cut-away showing beans (right side) -->
  <path d="M100 30 Q120 50 140 70 Q150 70 156 80 Q160 130 156 180 Q148 195 130 200 Q120 200 100 220" stroke="currentColor" stroke-dasharray="2 2" stroke-width="0.6"/>
  <!-- a couple of bean shapes peeking -->
  <g fill="currentColor" opacity="0.7">
    <ellipse cx="118" cy="80" rx="5" ry="8" transform="rotate(-15 118 80)"/>
    <ellipse cx="120" cy="100" rx="5" ry="8" transform="rotate(-20 120 100)"/>
    <ellipse cx="122" cy="130" rx="5" ry="8" transform="rotate(-10 122 130)"/>
    <ellipse cx="118" cy="160" rx="5" ry="8" transform="rotate(-15 118 160)"/>
  </g>
</svg>
