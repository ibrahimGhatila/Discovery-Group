---
/**
 * Uganda outline with origin region markers. Hand-traced approximation
 * — accurate enough to read as Uganda, deliberately simplified.
 * Cities/regions plotted in normalized 0–600 / 0–520 space.
 */
interface Region { x: number; y: number; label: string; commodity: string; }
interface Props {
  regions?: Region[];
  class?: string;
  showLabels?: boolean;
}

const defaultRegions: Region[] = [
  { x: 480, y: 230, label: 'Mt. Elgon', commodity: 'Arabica · Tea' },
  { x: 130, y: 290, label: 'Rwenzori', commodity: 'Arabica · Robusta · Cocoa' },
  { x: 410, y: 310, label: 'Kampala / Mukono', commodity: 'Vanilla · Namanve facility' },
  { x: 470, y: 110, label: 'Lira / Gulu', commodity: "Sesame · Bird's eye chilli" },
  { x: 240, y: 100, label: 'West Nile', commodity: 'Drugar Arabica · Sesame' },
  { x: 200, y: 410, label: 'Kabale / Kisoro', commodity: 'Beans & pulses' },
];

const { regions = defaultRegions, class: cls = '', showLabels = true } = Astro.props;
---
<svg viewBox="0 0 600 520" class={cls} fill="none" aria-label="Map of Uganda showing Discovery Group origin regions">
  <defs>
    <pattern id="ugStipple" x="0" y="0" width="6" height="6" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="currentColor" opacity="0.18"/>
    </pattern>
  </defs>

  <!-- Uganda outline — a deliberately stylised polygon approximation.
       Key reference points: north (South Sudan border), west (DRC), south
       (Tanzania/Rwanda/Lake Victoria), east (Kenya). -->
  <path d="
    M 220 70
    Q 260 50 320 55
    L 410 60
    Q 470 60 510 80
    L 540 110
    Q 555 150 540 200
    L 530 230
    Q 540 260 510 280
    L 520 320
    Q 510 360 470 380
    L 440 410
    Q 380 430 320 425
    L 270 440
    Q 220 455 175 440
    L 150 415
    Q 110 405 90 370
    L 80 310
    Q 60 270 80 220
    L 95 180
    Q 110 140 145 105
    L 170 85
    Q 195 75 220 70 Z
  " fill="url(#ugStipple)" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" opacity="0.85"/>

  <!-- Lake Victoria (south) — a partial bite out of the southeast -->
  <path d="
    M 440 410
    Q 470 405 500 410
    L 520 430
    Q 510 445 480 445
    L 440 440
    Z
  " fill="currentColor" opacity="0.08"/>
  <text x="475" y="430" font-family="Inter Variable, sans-serif" font-size="10" fill="currentColor" opacity="0.55" text-anchor="middle" font-style="italic">L. Victoria</text>

  <!-- Lake Albert (west, smaller) -->
  <path d="M 95 240 Q 100 250 90 270 Q 80 260 95 240 Z" fill="currentColor" opacity="0.08"/>

  <!-- Mountain glyphs for Mt. Elgon and Rwenzori -->
  <g stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.5">
    <path d="M 465 230 L 478 215 L 490 230 Z"/>
    <path d="M 478 215 L 478 218"/>
    <path d="M 115 290 L 130 270 L 145 290 Z"/>
    <path d="M 130 270 L 130 273"/>
  </g>

  <!-- Region markers -->
  {regions.map((r) => (
    <g>
      <circle cx={r.x} cy={r.y} r="14" fill="currentColor" opacity="0.08"/>
      <circle cx={r.x} cy={r.y} r="6" fill="currentColor" opacity="0.5"/>
      <circle cx={r.x} cy={r.y} r="2.5" fill="currentColor"/>
      {showLabels && (
        <g>
          <line x1={r.x} y1={r.y} x2={r.x + (r.x > 300 ? 24 : -24)} y2={r.y - 14} stroke="currentColor" stroke-width="0.6" opacity="0.5"/>
          <text
            x={r.x + (r.x > 300 ? 28 : -28)}
            y={r.y - 18}
            text-anchor={r.x > 300 ? 'start' : 'end'}
            font-family="Fraunces Variable, serif"
            font-style="italic"
            font-size="14"
            fill="currentColor"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 80"
          >{r.label}</text>
          <text
            x={r.x + (r.x > 300 ? 28 : -28)}
            y={r.y - 4}
            text-anchor={r.x > 300 ? 'start' : 'end'}
            font-family="Inter Variable, sans-serif"
            font-size="9"
            fill="currentColor"
            opacity="0.65"
            letter-spacing="0.06em"
            text-transform="uppercase"
          >{r.commodity}</text>
        </g>
      )}
    </g>
  ))}

  <!-- compass + scale ornament (top-right) -->
  <g transform="translate(560 30)" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.4">
    <circle cx="0" cy="0" r="12"/>
    <path d="M 0 -12 L 0 12 M -12 0 L 12 0"/>
    <text x="0" y="-18" text-anchor="middle" font-family="Inter Variable, sans-serif" font-size="8" fill="currentColor" opacity="0.6">N</text>
  </g>
</svg>
