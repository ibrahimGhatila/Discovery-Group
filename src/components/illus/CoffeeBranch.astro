---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 200 } = Astro.props;
---
<svg viewBox="0 0 200 240" width={size} fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
  <!-- main stem -->
  <path d="M100 20 Q98 80 96 130 Q94 175 100 220" stroke-width="1.5"/>
  <!-- side branches -->
  <path d="M96 60 Q72 55 50 48"/>
  <path d="M99 95 Q122 90 145 80"/>
  <path d="M95 130 Q70 130 48 122"/>
  <path d="M97 170 Q120 168 140 158"/>
  <!-- leaves (long pointed coffee leaves) -->
  <path d="M50 48 Q30 38 8 30 Q22 50 50 48Z" fill="currentColor" fill-opacity="0.12"/>
  <path d="M50 48 Q30 38 8 30 Q22 50 50 48Z"/>
  <path d="M50 48 Q42 30 38 12" stroke-width="0.8"/>
  <path d="M145 80 Q165 70 188 65 Q175 90 145 80Z" fill="currentColor" fill-opacity="0.12"/>
  <path d="M145 80 Q165 70 188 65 Q175 90 145 80Z"/>
  <path d="M145 80 Q160 70 168 56" stroke-width="0.8"/>
  <path d="M48 122 Q28 120 10 130 Q26 138 48 122Z" fill="currentColor" fill-opacity="0.12"/>
  <path d="M48 122 Q28 120 10 130 Q26 138 48 122Z"/>
  <path d="M48 122 Q34 130 22 138" stroke-width="0.8"/>
  <path d="M140 158 Q160 150 185 152 Q172 178 140 158Z" fill="currentColor" fill-opacity="0.12"/>
  <path d="M140 158 Q160 150 185 152 Q172 178 140 158Z"/>
  <path d="M140 158 Q156 162 168 178" stroke-width="0.8"/>
  <!-- cherries (clusters along the stem) -->
  <g fill="currentColor">
    <circle cx="94" cy="78" r="5"/><circle cx="104" cy="80" r="5"/>
    <circle cx="91" cy="112" r="5"/><circle cx="103" cy="115" r="5"/><circle cx="98" cy="106" r="5"/>
    <circle cx="92" cy="150" r="5"/><circle cx="103" cy="152" r="5"/>
    <circle cx="95" cy="190" r="5"/><circle cx="105" cy="192" r="5"/>
  </g>
  <g stroke="currentColor" stroke-width="0.7" fill="none">
    <line x1="94" y1="78" x2="96" y2="68"/><line x1="104" y1="80" x2="103" y2="70"/>
    <line x1="91" y1="112" x2="93" y2="103"/><line x1="103" y1="115" x2="102" y2="105"/>
    <line x1="98" y1="106" x2="98" y2="97"/>
    <line x1="92" y1="150" x2="94" y2="141"/><line x1="103" y1="152" x2="102" y2="143"/>
