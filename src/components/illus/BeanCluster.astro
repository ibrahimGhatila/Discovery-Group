---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 200 } = Astro.props;
---
<svg viewBox="0 0 200 240" width={size} fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
  <!-- a vining bean plant -->
  <path d="M40 30 Q70 60 80 100 Q90 140 75 200" stroke-width="1.5"/>
  <!-- trifoliate leaves -->
  <g>
    <path d="M75 70 Q55 65 40 70 Q55 80 75 70Z" fill="currentColor" fill-opacity="0.10"/>
    <path d="M75 70 Q55 65 40 70 Q55 80 75 70Z"/>
    <path d="M85 95 Q105 90 120 95 Q105 105 85 95Z" fill="currentColor" fill-opacity="0.10"/>
    <path d="M85 95 Q105 90 120 95 Q105 105 85 95Z"/>
    <path d="M85 140 Q105 138 122 144 Q108 152 85 140Z" fill="currentColor" fill-opacity="0.10"/>
    <path d="M85 140 Q105 138 122 144 Q108 152 85 140Z"/>
  </g>
  <!-- bean pods -->
  <g stroke="currentColor" fill="none" stroke-width="1.2">
    <path d="M120 110 Q135 130 145 165"/>
    <path d="M140 100 Q155 125 165 160"/>
    <path d="M160 95 Q172 120 180 150"/>
  </g>
  <!-- beans inside the pods (dots) -->
  <g fill="currentColor">
    <circle cx="125" cy="120" r="2"/><circle cx="130" cy="135" r="2"/><circle cx="136" cy="150" r="2"/>
    <circle cx="146" cy="115" r="2"/><circle cx="152" cy="130" r="2"/><circle cx="158" cy="145" r="2"/>
    <circle cx="164" cy="110" r="2"/><circle cx="170" cy="125" r="2"/><circle cx="175" cy="140" r="2"/>
  </g>
  <!-- a few loose beans at the bottom -->
  <g fill="currentColor" opacity="0.85">
    <ellipse cx="65" cy="215" rx="7" ry="4" transform="rotate(-15 65 215)"/>
    <ellipse cx="85" cy="220" rx="7" ry="4" transform="rotate(10 85 220)"/>
    <ellipse cx="105" cy="218" rx="7" ry="4" transform="rotate(-5 105 218)"/>
    <ellipse cx="125" cy="222" rx="7" ry="4" transform="rotate(20 125 222)"/>
  </g>
</svg>
