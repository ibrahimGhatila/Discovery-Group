---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 200 } = Astro.props;
---
<svg viewBox="0 0 200 240" width={size} fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
  <!-- main stem -->
  <path d="M100 18 Q100 120 100 220" stroke-width="1.5"/>
  <!-- pairs of long leaves down the stem -->
  <g>
    <path d="M100 50 Q60 45 30 60 Q60 70 100 50Z" fill="currentColor" fill-opacity="0.10"/>
    <path d="M100 50 Q60 45 30 60 Q60 70 100 50Z"/>
    <path d="M100 50 Q140 45 170 60 Q140 70 100 50Z" fill="currentColor" fill-opacity="0.10"/>
    <path d="M100 50 Q140 45 170 60 Q140 70 100 50Z"/>
  </g>
  <!-- seed capsules (oblong, paired) -->
  <g fill="currentColor" stroke="currentColor">
    <ellipse cx="86" cy="95" rx="6" ry="14" fill-opacity="0.2"/>
    <ellipse cx="86" cy="95" rx="6" ry="14"/>
    <ellipse cx="114" cy="95" rx="6" ry="14" fill-opacity="0.2"/>
    <ellipse cx="114" cy="95" rx="6" ry="14"/>
    <ellipse cx="84" cy="135" rx="6" ry="14" fill-opacity="0.2"/>
    <ellipse cx="84" cy="135" rx="6" ry="14"/>
    <ellipse cx="116" cy="135" rx="6" ry="14" fill-opacity="0.2"/>
    <ellipse cx="116" cy="135" rx="6" ry="14"/>
    <ellipse cx="86" cy="175" rx="6" ry="14" fill-opacity="0.2"/>
    <ellipse cx="86" cy="175" rx="6" ry="14"/>
    <ellipse cx="114" cy="175" rx="6" ry="14" fill-opacity="0.2"/>
    <ellipse cx="114" cy="175" rx="6" ry="14"/>
  </g>
  <!-- a few tiny seeds beneath -->
  <g fill="currentColor">
    <ellipse cx="92" cy="208" rx="2" ry="1.2"/>
    <ellipse cx="100" cy="212" rx="2" ry="1.2"/>
    <ellipse cx="108" cy="208" rx="2" ry="1.2"/>
    <ellipse cx="96" cy="218" rx="2" ry="1.2"/>
    <ellipse cx="104" cy="218" rx="2" ry="1.2"/>
  </g>
</svg>
