---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import { commodityPhoto } from '~/lib/commodities';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Products — Discovery Group" description="Ugandan coffee, cocoa, vanilla, sesame, bird's eye chilli, beans and pulses — graded, processed and exported from our Namanve facility.">

  {/* HEADER STRIP */}
  <section class="section-full">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-16 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow eyebrow-accent mb-5">Products</p>
          <h1 class="display-xl text-balance">
            Six Ugandan commodity lines.
          </h1>
        </div>
        <p class="lg:col-span-4 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          All sourced, processed and graded at our facility outside
          Kampala. Grades, MOQs and certifications on each page; samples
          on request.
        </p>
      </div>

      {/* 3 × 2 grid */}
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 lg:gap-x-8 gap-y-12">
        {commodities.map((c) => (
          <a href={`/products/${c.id}`} class="group block focus:outline-none">
            <Photo src={commodityPhoto[c.id] || 'coffee'} alt={c.data.title} aspect="4/5" class="transition-transform duration-500 group-hover:scale-[1.01]" />
            <div class="mt-5">
              <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] mb-2">{c.data.eyebrow}</p>
              <h2 class="h3 group-hover:text-[var(--color-clay)] transition-colors">{c.data.title}</h2>
              <p class="mt-3 text-sm text-[var(--color-ink-muted)] leading-relaxed line-clamp-2">{c.data.summary}</p>
              <p class="mt-4 text-sm font-medium text-[var(--color-clay)] inline-flex items-center gap-1.5">
                Full specification <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
              </p>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
