---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import { commodityPhoto } from '~/lib/commodities';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Products — Discovery Group" description="Ugandan coffee, cocoa, vanilla, sesame, bird's eye chilli, beans and pulses — graded, processed and exported from our Namanve facility.">

  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal max-w-3xl mb-14 lg:mb-20">
        <p class="eyebrow mb-5">Products</p>
        <h1 class="display-xl text-balance">Six Ugandan commodity lines.</h1>
        <p class="lede lede-wide mt-6">
          All sourced and processed at Namanve. Samples on request.
        </p>
      </div>

      <div class="reveal-stagger grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 lg:gap-x-8 gap-y-12">
        {commodities.map((c) => (
          <a href={`/products/${c.id}`} class="skim-card group focus:outline-none">
            <div class="photo-hover">
              <Photo src={commodityPhoto[c.id] || 'coffee'} alt={c.data.title} aspect="4/5" />
            </div>
            <div class="skim-card-body">
              <p class="skim-card-name">{c.data.title}</p>
              <div class="skim-card-name-meta">
                <span class="skim-card-meta">{c.data.eyebrow.split(' · ')[0]}</span>
                <span class="skim-card-meta text-[var(--color-clay)] opacity-0 group-hover:opacity-100 transition-opacity">View →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
