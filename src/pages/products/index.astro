---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import CommodityCard from '~/components/CommodityCard.astro';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Products — Discovery Group" description="Ugandan coffee, cocoa, vanilla, sesame, bird's eye chilli, beans and pulses — graded, processed and exported by Discovery Group from our Namanve facility.">
  <section class="pt-12 lg:pt-20">
    <Container>
      <SectionHeading
        level="h1"
        eyebrow="Products"
        title="Seven commodities. One floor."
        lede="Every line below is sourced, processed and graded at our Namanve facility outside Kampala. Indicative MOQs and grades on each page; lot-level documentation available on request with samples."
      />
    </Container>
  </section>

  <section class="mt-12 lg:mt-16">
    <Container>
      {commodities.map((c) => (
        <CommodityCard
          title={c.data.title}
          eyebrow={c.data.eyebrow}
          summary={c.data.summary}
          href={`/products/${c.id}`}
          regions={c.data.origin.regions}
          certifications={c.data.certifications}
          heroCaption={c.data.heroCaption}
          qualityMetricLabel={c.data.qualityMetricLabel}
          qualityMetricValue={c.data.qualityMetricValue}
          variant={c.data.order % 2 === 0 ? 'forest' : 'clay'}
        />
      ))}
    </Container>
  </section>
</BaseLayout>
