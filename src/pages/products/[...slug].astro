---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import EditorialPlate from '~/components/EditorialPlate.astro';
import CertBadge from '~/components/CertBadge.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityIllus, commodityTone } from '~/lib/commodities';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const commodities = await getCollection('commodities');
  return commodities.map((c) => ({
    params: { slug: c.id },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const c = entry.data;
const illus = commodityIllus[entry.id] || 'coffee';
const tone = commodityTone[entry.id] || 'clay';
const num = String((c.order || 1)).padStart(2, '0');
---
<BaseLayout title={`${c.title} — Discovery Group`} description={c.summary}>

  {/* HERO */}
  <section class="relative overflow-hidden border-b border-[var(--color-line)]" style="background: var(--color-paper-warm);">
    <Container class="py-20 lg:py-32">
      <a href="/products" class="inline-flex items-center gap-2 text-xs uppercase tracking-wider text-[var(--color-ink-muted)] hover:text-[var(--color-clay)] mb-12">
        <span aria-hidden="true">←</span>
        All commodities
      </a>

      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-end">
        <div class="lg:col-span-7 flex flex-col gap-6">
          <div class="flex items-baseline gap-4">
            <span class="font-mono text-xs text-[var(--color-clay)]">№ {num}</span>
            <p class="eyebrow">{c.eyebrow}</p>
          </div>
          <h1 class="display-xl text-balance">{c.title}</h1>
          <p class="lede lede-wide">{c.summary}</p>
          <div class="flex flex-wrap gap-3 mt-4">
            <a href={`/contact?commodity=${encodeURIComponent(c.title)}`} class="btn btn-primary">
              <span>Inquire about {c.title.toLowerCase()}</span>
              <span aria-hidden="true">→</span>
            </a>
            <a href="/products" class="btn btn-secondary">All commodities</a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <EditorialPlate caption={c.heroCaption} number={num} illus={illus} tone={tone} aspect="4/5" />
        </div>
      </div>
    </Container>
  </section>

  {/* DATA RIBBON */}
  <section style="background: var(--color-espresso); color: var(--color-paper);">
    <Container>
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x" style="--tw-divide-opacity: 0.2;">
        {[
          ['Origin regions', String(c.origin.regions.length)],
          c.origin.elevation ? ['Elevation', c.origin.elevation] : null,
          c.qualityMetricLabel ? [c.qualityMetricLabel, c.qualityMetricValue || '—'] : null,
          ['MOQ', c.moq],
        ].filter(Boolean).map((pair) => {
          const [k, v] = pair as [string, string];
          return (
            <div class="px-6 py-10 lg:px-10 lg:py-14 border-r last:border-r-0" style="border-color: color-mix(in srgb, var(--color-paper) 15%, transparent);">
              <p class="text-[0.625rem] uppercase tracking-[0.18em] mb-3" style="color: color-mix(in srgb, var(--color-paper) 55%, transparent);">{k}</p>
              <p class="font-display text-2xl lg:text-3xl tracking-tight text-balance" style="font-family: var(--font-display); font-weight: 480; line-height: 1.1;">{v}</p>
            </div>
          );
        })}
      </div>
    </Container>
  </section>

  {/* BODY + SPECS */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">Origin & sourcing</p>
          <div class="body-editorial">
            <Content />
          </div>

          <p class="eyebrow mt-16 mb-5">Origin regions</p>
          <ul class="max-w-prose">
            {c.origin.regions.map((r, idx) => (
              <li class="flex items-baseline gap-4 py-3 border-b border-[var(--color-line-soft)]">
                <span class="font-mono text-xs text-[var(--color-ink-muted)]">{String(idx + 1).padStart(2, '0')}</span>
                <span>{r}</span>
              </li>
            ))}
          </ul>

          {c.origin.seasons && (
            <div class="mt-12">
              <p class="eyebrow mb-3">Harvest seasons</p>
              <p class="text-[1.0625rem]">{c.origin.seasons}</p>
            </div>
          )}
        </div>

        <aside class="lg:col-span-5 lg:sticky lg:top-28 self-start">
          <div class="border border-[var(--color-line)] p-7 lg:p-10 bg-[var(--color-paper-warm)]">
            <div class="flex items-baseline justify-between mb-7">
              <p class="eyebrow">Spec sheet</p>
              <span class="font-mono text-xs text-[var(--color-ink-muted)]">№ {num}</span>
            </div>

            <p class="text-[0.625rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-4 mb-3">Grades</p>
            <dl class="border-t border-[var(--color-line-soft)]">
              {c.grades.map((g) => (
                <div class="spec-row">
                  <dt>{g.name}</dt>
                  <dd>{g.spec}</dd>
                </div>
              ))}
            </dl>

            <p class="text-[0.625rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-8 mb-3">Processing</p>
            <ul class="text-sm space-y-1.5">
              {c.processing.map((p) => <li class="flex gap-3"><span class="text-[var(--color-clay)]">·</span>{p}</li>)}
            </ul>

            <p class="text-[0.625rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-8 mb-3">Packaging</p>
            <p class="text-sm leading-relaxed">{c.packaging}</p>

            <p class="text-[0.625rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-8 mb-3">Incoterms</p>
            <ul class="text-sm space-y-1.5">
              {c.incoterms.map((i) => <li class="flex gap-3"><span class="text-[var(--color-clay)]">·</span>{i}</li>)}
            </ul>

            <p class="text-[0.625rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-8 mb-4">Certifications</p>
            <div class="flex flex-wrap gap-2">
              {c.certifications.map((cert) => <CertBadge cert={cert} />)}
            </div>

            <a href={`/contact?commodity=${encodeURIComponent(c.title)}`} class="btn btn-primary w-full justify-center mt-10">
              Request samples & docs
            </a>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  {/* GEOGRAPHY MOMENT */}
  <section class="py-24 lg:py-32" style="background: var(--color-espresso); color: var(--color-paper);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: var(--color-gold-light);">Geography</p>
          <h2 class="display-lg text-balance" style="color: var(--color-paper);">
            Where the <span class="italic-soft" style="color: var(--color-gold-light); font-weight: 380;">{c.title.toLowerCase()}</span> comes from.
          </h2>
          <p class="mt-7 text-[1.0625rem] leading-relaxed" style="color: color-mix(in srgb, var(--color-paper) 75%, transparent); max-width: 32rem;">
            All Discovery Group commodities are placed on the same origin
            map. Per-lot polygon-level geolocation files are provided with
            every EUDR-bound shipment.
          </p>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto text-[var(--color-paper)]" />
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
