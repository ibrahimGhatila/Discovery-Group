---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import CertBadge from '~/components/CertBadge.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityPhoto } from '~/lib/commodities';
import { photos } from '~/lib/photos';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const commodities = await getCollection('commodities');
  return commodities.map((c) => ({
    params: { slug: c.id },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const c = entry.data;
const photo = commodityPhoto[entry.id] || 'coffee';
const photoUrl = photos[photo];
---
<BaseLayout title={`${c.title} — Discovery Group`} description={c.summary}>

  {/* HERO */}
  <section class="section-full-hero w-full" style="background: var(--color-espresso);">
    <div class="absolute inset-0">
      <img src={photoUrl} alt={c.heroCaption} class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,11,8,0.35) 0%, rgba(15,11,8,0.15) 40%, rgba(15,11,8,0.85) 100%);"></div>
    </div>
    <Container class="relative pb-16 lg:pb-20">
      <a href="/products" class="inline-flex items-center gap-2 text-xs uppercase tracking-wider mb-8 self-start font-medium" style="color: rgba(255,255,255,0.75);">
        <span aria-hidden="true">←</span>
        All products
      </a>
      <p class="text-xs tracking-[0.22em] uppercase mb-5 font-medium" style="color: rgba(255,255,255,0.75);">{c.eyebrow}</p>
      <h1 class="display-xxl text-balance" style="color: white; max-width: 14ch;">{c.title}</h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed" style="color: rgba(255,255,255,0.82);">{c.summary}</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href={`/contact?commodity=${encodeURIComponent(c.title)}`} class="btn btn-light">
          Inquire about {c.title.toLowerCase()}
        </a>
        <a href="/products" class="btn btn-ghost-light">All products</a>
      </div>
    </Container>
  </section>

  {/* DATA + SPECS */}
  <section class="section">
    <Container>
      {/* Data ribbon */}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-8 border-y border-[var(--color-line)] py-10 mb-12">
        {[
          ['Origin regions', String(c.origin.regions.length)],
          c.origin.elevation ? ['Elevation', c.origin.elevation] : null,
          c.qualityMetricLabel ? [c.qualityMetricLabel, c.qualityMetricValue || '—'] : null,
          ['MOQ', c.moq],
        ].filter(Boolean).map((pair) => {
          const [k, v] = pair as [string, string];
          return (
            <div class="px-4 lg:px-6">
              <p class="text-[0.6875rem] uppercase tracking-[0.18em] mb-2 text-[var(--color-ink-muted)] font-medium">{k}</p>
              <p class="text-xl lg:text-2xl text-balance" style="font-weight: 600; letter-spacing: -0.025em; line-height: 1.15;">{v}</p>
            </div>
          );
        })}
      </div>

      {/* Body + sidebar */}
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-7">
          <p class="eyebrow eyebrow-accent mb-5">Origin and sourcing</p>
          <div class="body-editorial">
            <Content />
          </div>
        </div>

        <aside class="lg:col-span-5">
          <div class="border border-[var(--color-line)] p-7 lg:p-9 rounded-2xl" style="background: var(--color-paper-warm);">
            <p class="eyebrow eyebrow-accent mb-6">Specification</p>

            <p class="text-[0.6875rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mb-3 font-medium">Grades</p>
            <dl class="border-t border-[var(--color-line-soft)]">
              {c.grades.map((g) => (
                <div class="spec-row">
                  <dt>{g.name}</dt>
                  <dd>{g.spec}</dd>
                </div>
              ))}
            </dl>

            <p class="text-[0.6875rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-7 mb-3 font-medium">Processing</p>
            <ul class="text-sm space-y-1.5">
              {c.processing.map((p) => <li class="flex gap-3"><span class="text-[var(--color-clay)]">·</span>{p}</li>)}
            </ul>

            <p class="text-[0.6875rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-7 mb-3 font-medium">Packaging</p>
            <p class="text-sm leading-relaxed">{c.packaging}</p>

            <p class="text-[0.6875rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-7 mb-3 font-medium">Incoterms</p>
            <ul class="text-sm space-y-1.5">
              {c.incoterms.map((i) => <li class="flex gap-3"><span class="text-[var(--color-clay)]">·</span>{i}</li>)}
            </ul>

            <p class="text-[0.6875rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mt-7 mb-4 font-medium">Certifications</p>
            <div class="flex flex-wrap gap-2">
              {c.certifications.map((cert) => <CertBadge cert={cert} />)}
            </div>

            <a href={`/contact?commodity=${encodeURIComponent(c.title)}`} class="btn btn-primary w-full mt-8">
              Request samples and documentation
            </a>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  {/* GEOGRAPHY */}
  <section class="section" style="background: var(--color-espresso); color: white;">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: var(--color-gold-light);">Geography</p>
          <h2 class="display-lg text-balance" style="color: white;">
            Sourced across Uganda.
          </h2>
          <p class="mt-7 text-[1.0625rem] leading-relaxed max-w-md" style="color: rgba(245,243,238,0.75);">
            Per-lot polygon geolocation is provided with every EUDR-bound
            shipment, accompanied by cooperative-level provenance
            documentation.
          </p>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto" style="color: white;" />
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
