---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { photos } from '~/lib/photos';
---
<BaseLayout title="Sustainability — Discovery Group" description="Direct cooperative sourcing, traceability, certifications and EUDR readiness.">

  {/* HERO */}
  <section class="grid lg:grid-cols-2 min-h-[70vh] border-b border-[var(--color-line)]">
    <div class="reveal flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-20 lg:py-24">
      <p class="eyebrow mb-5">Sustainability</p>
      <h1 class="display-xl text-balance">We invest in the cooperatives we source from.</h1>
      <p class="lede lede-wide mt-7">
        Better paying. Better documented. Better farmed.
      </p>
    </div>
    <div class="relative min-h-[40vh] photo-hover">
      <img src={photos.cooperative} alt="Cooperative members at the season-planning gathering" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    </div>
  </section>

  {/* STATS */}
  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal mb-12">
        <p class="eyebrow mb-5">Impact</p>
        <h2 class="display-lg text-balance">Indicative scale.</h2>
      </div>
      <div class="reveal-stagger grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 border-t border-[var(--color-line)] pt-12">
        {[
          ['~50', 'Discovery employees'],
          ['900+', 'Smallholder partners'],
          ['7', 'Commodity lines'],
          ['100%', 'EUDR-compliant lots'],
        ].map(([k, v]) => (
          <div class="stat">
            <p class="stat-number">{k}</p>
            <p class="stat-label">{v}</p>
          </div>
        ))}
      </div>
      <p class="reveal mt-12 text-sm text-[var(--color-ink-muted)] max-w-2xl">
        Indicative figures. Replaced with audited annual figures once
        the Discovery 2025 impact review is published.
      </p>
    </Container>
  </section>

  {/* COMMITMENTS */}
  <section class="section">
    <Container>
      <div class="reveal mb-14">
        <p class="eyebrow mb-5">Commitments</p>
        <h2 class="display-lg text-balance">Four practical programmes.</h2>
      </div>
      <div class="reveal-stagger grid lg:grid-cols-2 gap-x-12 gap-y-12">
        {[
          ['01', 'Traceability', 'Every lot traced to its cooperative. EUDR-bound shipments carry polygon geolocation per producer plot.'],
          ['02', 'Premium payment', 'Quality premium above commodity price, against verified cup scores, cut tests or vanillin readings.'],
          ['03', 'Origin training', 'Season-opening agronomy and post-harvest clinics with cooperatives.'],
          ['04', 'Women in the supply', 'Training programmes targeted at women-led plots. Demographic split recorded per lot.'],
        ].map(([num, title, body]) => (
          <article class="flex gap-6">
            <span class="font-mono text-xs text-[var(--color-clay)] pt-1">{num}</span>
            <div>
              <h3 class="h2 mb-3">{title}</h3>
              <p class="text-[var(--color-ink-muted)] leading-relaxed max-w-prose">{body}</p>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  {/* CERTIFICATIONS */}
  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal mb-12">
        <p class="eyebrow mb-5">Certifications</p>
        <h2 class="display-lg text-balance">Documented. Attached to the lot.</h2>
      </div>
      <div class="reveal-stagger grid grid-cols-3 lg:grid-cols-6 gap-px border border-[var(--color-line)]">
        {['Organic', 'Rainforest Alliance', 'Fairtrade', 'Halal', 'EUDR', 'UCDA'].map((c) => (
          <div class="px-6 py-10 flex items-center justify-center text-center bg-[var(--color-paper-pure)]">
            <p class="text-xs font-medium uppercase tracking-[0.14em] text-[var(--color-ink-muted)]">{c}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* EUDR */}
  <section class="section" style="background: var(--color-paper-warm);">
    <Container>
      <div class="reveal grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5">For EU buyers</p>
          <h2 class="display-lg text-balance">EUDR readiness.</h2>
        </div>
        <div class="lg:col-span-7 body-editorial">
          <p>
            For coffee, cocoa and rubber-adjacent shipments to the EU, we
            prepare the full EUDR documentation package: polygon
            geolocation per producer plot, due-diligence statement and
            DDS reference number.
          </p>
          <p>
            Geolocation is collected at the cooperative aggregation point
            during buying. The file ships with the consignment.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* GEOGRAPHY */}
  <section class="section" style="background: var(--color-espresso); color: white;">
    <Container>
      <div class="reveal grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: rgba(255,255,255,0.6);">Geography</p>
          <h2 class="display-lg text-balance" style="color: white;">
            Six Ugandan regions.
          </h2>
          <p class="lede mt-6" style="color: rgba(255,255,255,0.7);">
            Each commodity is traceable to its belt, cooperative and season.
          </p>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto" style="color: white;" />
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
