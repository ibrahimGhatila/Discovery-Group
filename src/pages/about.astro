---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import { photos } from '~/lib/photos';
import { site } from '~/lib/site';
---
<BaseLayout title="About — Discovery Group" description="Discovery Group is a vertically integrated Ugandan agri-commodity exporter, founded in 2014, operating from Plot 92, Namanve Industrial Area, Kampala.">

  {/* HERO */}
  <section class="relative w-full" style="background: var(--color-espresso);">
    <div class="relative h-[60vh] min-h-[420px] max-h-[640px] w-full overflow-hidden">
      <img src={photos.warehouse} alt="Discovery Group's Namanve processing facility" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,11,8,0.4) 0%, rgba(15,11,8,0.2) 40%, rgba(15,11,8,0.85) 100%);"></div>

      <Container class="relative h-full flex flex-col justify-end pb-16 lg:pb-20">
        <p class="text-xs tracking-[0.22em] uppercase mb-5" style="color: rgba(255,255,255,0.75);">About</p>
        <h1 class="text-balance" style="font-family: var(--font-display); font-weight: 480; font-size: clamp(2.25rem, 5vw + 1rem, 4.75rem); line-height: 1.05; letter-spacing: -0.025em; color: white; max-width: 18ch;">
          A Ugandan exporter, operated as one company.
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed" style="color: rgba(255,255,255,0.8);">
          Discovery Trading Ltd was founded in Kampala in 2014 to bring
          smallholder Ugandan commodities to world markets on
          origin-controlled, transparent terms. The group today operates
          as Discovery Group, with three legal entities, one supervising
          operation, and one consumer brand.
        </p>
      </Container>
    </div>
  </section>

  {/* LEGAL STRUCTURE */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-12 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">Structure</p>
          <h2 class="display-lg text-balance">
            Three legal entities, one operation.
          </h2>
        </div>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          ['Discovery Trading Ltd', 'Founded 2014. Agro-commodity export. Parent of the operating group.'],
          ['Discovery Impex Limited', 'Agro-trading and processing of coffee, cocoa and vanilla.'],
          ['Discovery Coftea Limited', 'Brand owner of Orocafe — finished-coffee processing and packaging since 2022.'],
        ].map(([k, v]) => (
          <div class="border-t border-[var(--color-line)] pt-6">
            <p class="font-display text-xl mb-3 tracking-tight" style="font-family: var(--font-display); font-weight: 540;">{k}</p>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* FACILITY */}
  <section class="py-24 lg:py-32" style="background: var(--color-paper-warm);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <Photo src="roasting" alt="Plot 92, Namanve Industrial Area — Discovery processing floor" aspect="3/2" />
        </div>
        <div class="lg:col-span-5 flex flex-col gap-6">
          <p class="eyebrow">The facility</p>
          <h2 class="display-lg text-balance">Plot 92, Namanve.</h2>
          <p class="text-[var(--color-ink-muted)] leading-relaxed">
            Twelve kilometres outside Kampala on the Jinja road, Namanve
            Industrial Area is Uganda's anchor industrial zone and our home
            since 2014. Coffee dry-milling, cocoa cut-test grading, vanilla
            conditioning, sesame and pulse optical sorting, and Orocafe
            roasting and packing all run from this site.
          </p>
          <address class="not-italic text-sm leading-relaxed text-[var(--color-ink-muted)] border-t border-[var(--color-line)] pt-5">
            {site.legalName}<br />
            {site.address.line1}<br />
            {site.address.line2}
          </address>
        </div>
      </div>
    </Container>
  </section>

  {/* LEADERSHIP */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-14 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">Leadership</p>
          <h2 class="display-lg text-balance">
            Operators, not brokers.
          </h2>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-x-12 gap-y-16">
        <article class="grid grid-cols-12 gap-6">
          <div class="col-span-5">
            <Photo src="cupping" alt="Mustafa Hashim — portrait at Namanve" aspect="4/5" />
          </div>
          <div class="col-span-7 flex flex-col gap-3">
            <p class="eyebrow">Chief Executive</p>
            <h3 class="font-display text-2xl tracking-tight" style="font-family: var(--font-display); font-weight: 540;">Mustafa Hashim</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
              Chief Executive of Discovery Group. MBA, Harvard Business
              School (2012); leadership credentials, London Business
              School (2010). Previously Managing Director at Baaz
              International.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-12 gap-6">
          <div class="col-span-5">
            <Photo src="hands" alt="Senior operations portrait forthcoming" aspect="4/5" />
          </div>
          <div class="col-span-7 flex flex-col gap-3">
            <p class="eyebrow">Operations</p>
            <h3 class="font-display text-2xl tracking-tight" style="font-family: var(--font-display); font-weight: 540;">Operations Lead</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
              Senior leadership placeholder for the operations function —
              to be replaced with the named lead and verified biography.
            </p>
          </div>
        </article>
      </div>
    </Container>
  </section>

  {/* TIMELINE */}
  <section class="py-24 lg:py-32" style="background: var(--color-paper-warm);">
    <Container>
      <p class="eyebrow mb-6">Timeline</p>
      <h2 class="display-lg text-balance mb-14">
        From founding to Orocafe.
      </h2>
      <ol class="grid sm:grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-8">
        {[
          ['2014', 'Discovery Trading Ltd founded in Kampala. First Robusta and Arabica export shipments.'],
          ['2016', 'Discovery Impex Limited registered for processing operations. Vanilla and chilli lines added.'],
          ['2019', 'Exhibits at World of Coffee Berlin. Sesame and pulses scaled at Namanve.'],
          ['2022', 'Orocafe launched — finished coffee processing, packaging and sales at origin.'],
        ].map(([year, body]) => (
          <li class="border-t border-[var(--color-line)] pt-6">
            <p style="font-family: var(--font-display); font-weight: 480; font-size: 2.5rem; color: var(--color-clay); line-height: 1;">{year}</p>
            <p class="mt-4 text-sm leading-relaxed text-[var(--color-ink-muted)]">{body}</p>
          </li>
        ))}
      </ol>
    </Container>
  </section>
</BaseLayout>
