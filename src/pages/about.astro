---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import { photos } from '~/lib/photos';
import { site } from '~/lib/site';
---
<BaseLayout title="About — Discovery Group" description="Discovery Group is a vertically integrated Ugandan agri-commodity exporter, founded in 2014, operating from Plot 92, Namanve Industrial Area, Kampala.">

  {/* HERO — short, image right */}
  <section class="grid lg:grid-cols-2 min-h-[70vh] border-b border-[var(--color-line)]">
    <div class="reveal flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-20 lg:py-24">
      <p class="eyebrow mb-5">About</p>
      <h1 class="display-xl text-balance">A Ugandan exporter, operated as one company.</h1>
      <p class="lede lede-wide mt-7">
        Founded in Kampala, 2014. Three legal entities. One operation. One consumer brand.
      </p>
    </div>
    <div class="relative min-h-[40vh] photo-hover">
      <img src={photos.warehouse} alt="Discovery Group's Namanve processing facility" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    </div>
  </section>

  {/* STRUCTURE */}
  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal mb-12">
        <p class="eyebrow mb-5">Structure</p>
        <h2 class="display-lg text-balance">Three entities, one operation.</h2>
      </div>
      <div class="reveal-stagger grid sm:grid-cols-3 gap-x-10 gap-y-10 border-t border-[var(--color-line)] pt-12">
        {[
          ['Discovery Trading Ltd', 'Parent company. Founded 2014.'],
          ['Discovery Impex Limited', 'Trading and processing.'],
          ['Discovery Coftea Limited', 'Brand owner — Orocafe.'],
        ].map(([k, v]) => (
          <div>
            <p class="h3 mb-3">{k}</p>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* FACILITY */}
  <section class="grid lg:grid-cols-2 min-h-[60vh]" style="background: var(--color-paper-warm);">
    <div class="relative photo-hover min-h-[40vh]">
      <img src={photos.roasting} alt="Plot 92, Namanve Industrial Area" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="reveal flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-20 lg:py-24">
      <p class="eyebrow mb-5">Facility</p>
      <h2 class="display-lg text-balance">Plot 92, Namanve.</h2>
      <p class="lede mt-6">
        Twelve kilometres outside Kampala. Coffee dry-milling, cocoa cut-test grading, vanilla curing, optical sorting and Orocafe roasting — all on one floor.
      </p>
      <address class="not-italic text-sm leading-relaxed text-[var(--color-ink-muted)] border-t border-[var(--color-line)] pt-5 mt-8">
        {site.legalName}<br />
        {site.address.line1}<br />
        {site.address.line2}
      </address>
    </div>
  </section>

  {/* LEADERSHIP */}
  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal mb-12">
        <p class="eyebrow mb-5">Leadership</p>
        <h2 class="display-lg text-balance">Operators, not brokers.</h2>
      </div>
      <div class="reveal-stagger grid lg:grid-cols-2 gap-x-12 gap-y-14">
        <article class="grid grid-cols-12 gap-6">
          <div class="col-span-5">
            <Photo src="cupping" alt="Mustafa Hashim portrait" aspect="4/5" />
          </div>
          <div class="col-span-7 flex flex-col gap-3 self-end">
            <p class="eyebrow eyebrow-bare">Chief Executive</p>
            <h3 class="h2">Mustafa Hashim</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
              MBA, Harvard Business School. Previously Managing Director at Baaz International.
            </p>
          </div>
        </article>
        <article class="grid grid-cols-12 gap-6">
          <div class="col-span-5">
            <Photo src="hands" alt="Operations portrait forthcoming" aspect="4/5" />
          </div>
          <div class="col-span-7 flex flex-col gap-3 self-end">
            <p class="eyebrow eyebrow-bare">Operations</p>
            <h3 class="h2">Operations Lead</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
              Senior leadership — to be replaced with the named lead.
            </p>
          </div>
        </article>
      </div>
    </Container>
  </section>

  {/* TIMELINE */}
  <section class="section" style="background: var(--color-paper-warm);">
    <Container>
      <div class="reveal mb-12">
        <p class="eyebrow mb-5">Timeline</p>
        <h2 class="display-lg text-balance">From founding to Orocafe.</h2>
      </div>
      <ol class="reveal-stagger grid sm:grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-8 border-t border-[var(--color-line)] pt-12">
        {[
          ['2014', 'Discovery Trading Ltd founded in Kampala.'],
          ['2016', 'Discovery Impex Ltd. Vanilla, chilli added.'],
          ['2019', 'World of Coffee Berlin. Sesame and pulses scaled.'],
          ['2022', 'Orocafe launched at Namanve.'],
        ].map(([year, body]) => (
          <li class="stat">
            <p style="font-weight: 600; font-size: 2.75rem; color: var(--color-clay); line-height: 1; letter-spacing: -0.04em;">{year}</p>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-ink-muted)]">{body}</p>
          </li>
        ))}
      </ol>
    </Container>
  </section>
</BaseLayout>
