---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import EditorialPlate from '~/components/EditorialPlate.astro';
import { site } from '~/lib/site';
---
<BaseLayout title="About — Discovery Group" description="Discovery Group is a vertically integrated Ugandan agri-commodity exporter, founded in 2014, operating from Plot 92, Namanve Industrial Area, Kampala.">

  <section class="py-20 lg:py-32 border-b border-[var(--color-line)]">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-6">№ 07 · About</p>
          <h1 class="display-xl text-balance">
            A Ugandan exporter that <span class="italic-soft" style="color: var(--color-clay); font-weight: 380;">operates as one.</span>
          </h1>
          <p class="lede lede-wide mt-8">
            Discovery Trading Ltd was founded in Kampala in 2014 to put
            smallholder Ugandan agri-commodities into world markets on
            origin-controlled, transparent terms. Today the company — trading
            as Discovery Group, with Discovery Impex Limited handling
            processing and Discovery Coftea Limited operating the Orocafe
            consumer brand — runs one of Uganda's most integrated
            agri-commodity operations.
          </p>
        </div>
        <div class="lg:col-span-5">
          <EditorialPlate caption="Namanve processing floor, dry-mill outfeed" number="07" illus="coffee" tone="clay" aspect="4/5" />
        </div>
      </div>
    </Container>
  </section>

  {/* LEGAL STRUCTURE */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-12 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">№ 01 · Structure</p>
          <h2 class="display-lg text-balance">
            Three legal entities. <span class="italic-soft" style="color: var(--color-clay); font-weight: 380;">One operating company.</span>
          </h2>
        </div>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          ['01', 'Discovery Trading Ltd', 'Founded 2014 · agro-commodity export. The parent of the operating group.'],
          ['02', 'Discovery Impex Limited', 'Agro-trading and processing of coffee, cocoa and vanilla.'],
          ['03', 'Discovery Coftea Limited', 'Brand owner of Orocafe — finished-coffee processing and packaging at origin since 2022.'],
        ].map(([num, k, v]) => (
          <div class="border-t border-[var(--color-line)] pt-6">
            <span class="font-mono text-xs text-[var(--color-clay)]">{num}</span>
            <p class="font-display text-xl mt-3 mb-3 tracking-tight" style="font-family: var(--font-display); font-weight: 540;">{k}</p>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* FACILITY */}
  <section class="py-24 lg:py-32" style="background: var(--color-paper-warm);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-7">
          <EditorialPlate caption="Plot 92, Namanve Industrial Area — Discovery processing floor" number="02" illus="coffee" tone="clay" aspect="3/2" />
        </div>
        <div class="lg:col-span-5 flex flex-col gap-6">
          <p class="eyebrow">№ 02 · The facility</p>
          <h2 class="display-lg text-balance">Plot 92, Namanve.</h2>
          <p class="text-[var(--color-ink-muted)] leading-relaxed">
            Twelve kilometres outside Kampala on the Jinja road, Namanve
            Industrial Area is Uganda's anchor industrial zone and our home
            since the founding year. Coffee dry-milling, cocoa cut-test
            grading, vanilla conditioning, sesame and pulse optical
            sorting, and Orocafe roasting and packing all run from this
            site.
          </p>
          <address class="not-italic text-sm leading-relaxed text-[var(--color-ink-muted)] border-t border-[var(--color-line)] pt-5">
            {site.legalName}<br />
            {site.address.line1}<br />
            {site.address.line2}
          </address>
        </div>
      </div>
    </Container>
  </section>

  {/* LEADERSHIP */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-14 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">№ 03 · Leadership</p>
          <h2 class="display-lg text-balance">
            Operators. <span class="italic-soft" style="color: var(--color-clay); font-weight: 380;">Not brokers.</span>
          </h2>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-x-12 gap-y-16">
        <article class="grid grid-cols-12 gap-6">
          <div class="col-span-5">
            <EditorialPlate caption="Mustafa Hashim — portrait at Namanve" number="01" illus="coffee" tone="dark" aspect="4/5" />
          </div>
          <div class="col-span-7 flex flex-col gap-3">
            <p class="eyebrow">Chief Executive</p>
            <h3 class="font-display text-2xl tracking-tight" style="font-family: var(--font-display); font-weight: 540;">Mustafa Hashim</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
              Chief Executive of Discovery Group. MBA, Harvard Business
              School (2012); leadership credentials, London Business School
              (2010). Previously Managing Director at Baaz International.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-12 gap-6">
          <div class="col-span-5">
            <EditorialPlate caption="Senior operations — portrait forthcoming" number="02" illus="coffee" tone="forest" aspect="4/5" />
          </div>
          <div class="col-span-7 flex flex-col gap-3">
            <p class="eyebrow">Operations</p>
            <h3 class="font-display text-2xl tracking-tight" style="font-family: var(--font-display); font-weight: 540;">[Operations Lead]</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
              Senior leadership placeholder for the operations function — to
              be replaced with the named lead and verified biography.
            </p>
          </div>
        </article>
      </div>
    </Container>
  </section>

  {/* TIMELINE */}
  <section class="py-24 lg:py-32" style="background: var(--color-paper-warm);">
    <Container>
      <p class="eyebrow mb-6">№ 04 · Timeline</p>
      <h2 class="display-lg text-balance mb-14">
        From founding <span class="italic-soft" style="color: var(--color-clay); font-weight: 380;">to Orocafe.</span>
      </h2>
      <ol class="grid sm:grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-8">
        {[
          ['2014', '01', 'Discovery Trading Ltd founded in Kampala. First Robusta and Arabica export shipments.'],
          ['2016', '02', 'Discovery Impex Limited registered for processing operations. Vanilla and chilli lines added.'],
          ['2019', '03', 'Exhibits at World of Coffee Berlin. Sesame and pulses scaled at Namanve.'],
          ['2022', '04', 'Orocafe launched — finished coffee processing, packaging and sales at origin.'],
        ].map(([year, num, body]) => (
          <li class="border-t border-[var(--color-line)] pt-6">
            <span class="font-mono text-xs text-[var(--color-ink-muted)]">{num}</span>
            <p class="font-display tracking-tight mt-3 mb-4" style="font-family: var(--font-display); font-weight: 480; font-size: 2.5rem; color: var(--color-clay); line-height: 1;">{year}</p>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{body}</p>
          </li>
        ))}
      </ol>
    </Container>
  </section>
</BaseLayout>
