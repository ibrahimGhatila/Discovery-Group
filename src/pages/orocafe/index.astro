---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import OrocafeProductCard from '~/components/OrocafeProductCard.astro';
import { photos } from '~/lib/photos';
import { getCollection } from 'astro:content';

const products = (await getCollection('orocafeProducts'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---
<BaseLayout title="Orocafe — Ugandan coffee, roasted at origin" description="Single-origin Ugandan Arabica and Robusta from Mt. Elgon and the Rwenzori — roasted and packed at Namanve. A Discovery Group brand." brand="orocafe">

  {/* HERO — full-bleed dark espresso */}
  <section class="relative w-full" style="background: var(--color-night);">
    <div class="relative h-[92vh] min-h-[640px] max-h-[920px] w-full overflow-hidden">
      <img src={photos.heroOrocafe} alt="An espresso pour at the Orocafe roastery" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,6,5,0.65) 0%, rgba(10,6,5,0.25) 50%, rgba(10,6,5,0.85) 100%);"></div>

      <Container class="relative h-full flex flex-col justify-end pb-20 lg:pb-28">
        <p class="text-xs tracking-[0.22em] uppercase mb-6" style="color: var(--color-oro);">
          A Discovery Group brand · Roasted in Kampala since 2022
        </p>
        <h1 class="text-balance" style="font-family: var(--font-display); font-weight: 460; font-size: clamp(2.5rem, 7vw + 1rem, 6.5rem); line-height: 1.0; letter-spacing: -0.03em; color: white; max-width: 14ch;">
          Ugandan coffee, roasted at origin.
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-relaxed" style="color: rgba(240,230,210,0.85);">
          Single-origin Arabica from Mt. Elgon, single-origin Robusta from
          the Rwenzori. Whole bean and ground. Nespresso®-compatible
          capsules. Drip bags. Premixes. Instant teas.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/orocafe/products" class="btn btn-primary">Explore the range</a>
          <a href="#story" class="btn btn-secondary">Our story</a>
        </div>
      </Container>
    </div>
  </section>

  {/* FEATURED PRODUCTS */}
  <section class="py-24 lg:py-32 border-t" style="border-color: var(--color-line);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-14 lg:mb-20 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow mb-5" style="color: var(--color-oro);">Featured</p>
          <h2 class="display-lg text-balance" style="color: var(--color-paper);">
            From the roastery.
          </h2>
        </div>
        <a href="/orocafe/products" class="lg:col-span-4 text-sm font-medium uppercase tracking-wider lg:text-right hover:opacity-70" style="color: var(--color-oro);">
          See all products →
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 lg:gap-x-8 gap-y-14">
        {products.map((p, i) => (
          <OrocafeProductCard
            title={p.data.title}
            category={p.data.category}
            origin={p.data.origin}
            flavourNotes={p.data.flavourNotes}
            sizes={p.data.sizes}
            heroCaption={p.data.heroCaption}
            href={`/orocafe/products/${p.id}`}
            index={i + 1}
          />
        ))}
      </div>
    </Container>
  </section>

  {/* STORY */}
  <section id="story" class="py-24 lg:py-32" style="background: var(--color-night);">
    <Container>
      <p class="eyebrow mb-12" style="color: var(--color-oro);">Story</p>
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-6">
          <h2 class="display-xl text-balance" style="color: var(--color-paper); font-weight: 460;">
            We were exporters first. Now we roast.
          </h2>
        </div>
        <div class="lg:col-span-6 flex flex-col gap-6 text-[1.0625rem] leading-relaxed" style="color: rgba(240,230,210,0.8);">
          <p>
            For eight years, Discovery Group shipped Ugandan coffee green
            to roasters worldwide. We knew the lots intimately — cupped
            them, graded them, GrainPro-sealed them. We just never got to
            roast them.
          </p>
          <p>
            In 2022 we built the roastery at Namanve. Orocafe was born of
            a simple thought: if we own the line from cherry to FCL, why
            should the cup happen anywhere else? Why not roast Ugandan
            coffee in Uganda?
          </p>
          <p style="color: var(--color-paper);">
            "Oro" is Greek for mountain — respect for the African
            landscape that gave us the bean. It is also gold — what coffee
            is, to a producing country. Orocafe is both.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ORIGIN DIPTYCH */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 mb-14 lg:mb-20 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5" style="color: var(--color-oro);">Origin</p>
          <h2 class="display-lg text-balance" style="color: var(--color-paper);">
            Two mountains, one country.
          </h2>
        </div>
        <p class="lg:col-span-5 text-[1.0625rem] leading-relaxed" style="color: var(--color-ink-muted); max-width: 32rem;">
          Mt. Elgon Arabica is bright and fruit-forward. Rwenzori Robusta
          is dark, full-bodied and built for milk. Orocafe takes both
          seriously.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-8">
        <article class="flex flex-col gap-5">
          <Photo src="landscape" alt="Mt. Elgon slopes at washing-station altitude" aspect="4/5" />
          <div>
            <p class="eyebrow mb-2" style="color: var(--color-oro);">Mt. Elgon · Arabica</p>
            <p class="text-base leading-relaxed text-[var(--color-ink-muted)] max-w-prose">
              1,650–2,300 m.a.s.l. Volcanic soil. Washed processing.
              Bright acidity, blackcurrant, cocoa nib.
            </p>
          </div>
        </article>
        <article class="flex flex-col gap-5">
          <Photo src="drying" alt="Rwenzori sun-drying beds at first light" aspect="4/5" />
          <div>
            <p class="eyebrow mb-2" style="color: var(--color-oro);">Rwenzori · Robusta</p>
            <p class="text-base leading-relaxed text-[var(--color-ink-muted)] max-w-prose">
              900–1,500 m.a.s.l. Equatorial belt. Natural processing.
              Dark chocolate, hazelnut, full body.
            </p>
          </div>
        </article>
      </div>
    </Container>
  </section>

  {/* DISTRIBUTOR CTA */}
  <section class="py-24 lg:py-32 border-t" style="border-color: var(--color-line); background: var(--color-paper-deep);">
    <Container>
      <div class="flex flex-col items-center text-center max-w-3xl mx-auto gap-7">
        <p class="eyebrow" style="color: var(--color-oro);">Wholesale and private label</p>
        <h2 class="display-lg text-balance" style="color: var(--color-paper);">
          Stocking Orocafe? Tell us where.
        </h2>
        <p class="text-lg leading-relaxed" style="color: var(--color-ink-muted); max-width: 40rem;">
          Distributors, hotel groups, coffee programmes and private-label
          partners — we'd like to hear from you. Send a brief and we'll
          come back within two business days.
        </p>
        <a href="/contact" class="btn btn-primary mt-4">Distributor inquiry</a>
      </div>
    </Container>
  </section>
</BaseLayout>
