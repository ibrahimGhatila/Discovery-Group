---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import EditorialPlate from '~/components/EditorialPlate.astro';
import CertBadge from '~/components/CertBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('orocafeProducts');
  return products.map((p) => ({
    params: { slug: p.id },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const p = entry.data;
const num = String(p.order || 1).padStart(2, '0');
---
<BaseLayout title={`${p.title} — Orocafe`} description={p.summary} brand="orocafe">

  <section class="py-16 lg:py-24 border-b" style="border-color: var(--color-line);">
    <Container>
      <a href="/orocafe/products" class="inline-flex items-center gap-2 text-xs uppercase tracking-wider mb-10" style="color: var(--color-ink-muted);">
        <span aria-hidden="true">←</span>
        All Orocafe products
      </a>

      <div class="grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-6">
          <EditorialPlate caption={p.heroCaption} number={num} illus="cup" tone="oro" aspect="4/5" />
        </div>

        <div class="lg:col-span-6 flex flex-col gap-6 lg:pt-8">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-xs" style="color: var(--color-oro);">№ {num}</span>
            <p class="eyebrow" style="color: var(--color-oro);">{p.category} · {p.origin}</p>
          </div>
          <h1 class="display-lg text-balance" style="font-style: italic; font-weight: 460;">{p.title}</h1>
          <p class="lede lede-wide">{p.summary}</p>

          <div class="grid grid-cols-2 gap-x-6 gap-y-5 mt-2">
            {[
              ['Origin', p.origin],
              ['Process', p.process],
              p.variety ? ['Variety', p.variety] : null,
              p.roast ? ['Roast', p.roast] : null,
            ].filter(Boolean).map((pair) => {
              const [k, v] = pair as [string, string];
              return (
                <div class="border-t pt-3" style="border-color: var(--color-line);">
                  <p class="eyebrow mb-1.5" style="color: var(--color-ink-muted);">{k}</p>
                  <p class="text-sm">{v}</p>
                </div>
              );
            })}
          </div>

          <div class="border-t pt-5" style="border-color: var(--color-line);">
            <p class="eyebrow mb-3" style="color: var(--color-ink-muted);">Flavour notes</p>
            <ul class="flex flex-wrap gap-2">
              {p.flavourNotes.map((note) => (
                <li class="border px-3 py-1 text-sm" style="border-color: var(--color-line);">{note}</li>
              ))}
            </ul>
          </div>

          <div class="border-t pt-5" style="border-color: var(--color-line);">
            <p class="eyebrow mb-3" style="color: var(--color-ink-muted);">Sizes</p>
            <ul class="flex flex-wrap gap-2">
              {p.sizes.map((s) => (
                <li class="border px-3 py-1 text-xs font-mono" style="border-color: var(--color-line);">{s}</li>
              ))}
            </ul>
          </div>

          {p.certifications.length > 0 && (
            <div class="border-t pt-5" style="border-color: var(--color-line);">
              <p class="eyebrow mb-3" style="color: var(--color-ink-muted);">Certifications</p>
              <div class="flex flex-wrap gap-2">
                {p.certifications.map((c) => <CertBadge cert={c} />)}
              </div>
            </div>
          )}

          <div class="border-t pt-6 mt-2" style="border-color: var(--color-line);">
            <a href="/contact" class="btn btn-primary">
              <span>Distributor inquiry</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-20 lg:py-28">
    <Container narrow>
      <div class="body-editorial">
        <Content />
      </div>
    </Container>
  </section>
</BaseLayout>
