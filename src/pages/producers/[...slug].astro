---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import type { PhotoKey } from '~/lib/photos';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const producers = await getCollection('producers');
  return producers.map((p) => ({
    params: { slug: p.id },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const p = entry.data;

const photoByCommodity: Record<string, PhotoKey> = {
  'Arabica coffee': 'producerCoffee',
  'Robusta coffee': 'producerCoffee',
  'Cocoa': 'producerCocoa',
  'Vanilla': 'producerVanilla',
  "Bird's eye chilli": 'chilli',
  'Sesame': 'sesame',
};
---
<BaseLayout title={`${p.name} — Discovery Group`} description={p.summary}>

  <section class="py-16 lg:py-24 border-b border-[var(--color-line)]" style="background: var(--color-paper-warm);">
    <Container>
      <a href="/producers" class="inline-flex items-center gap-2 text-xs uppercase tracking-wider text-[var(--color-ink-muted)] hover:text-[var(--color-clay)] mb-10">
        <span aria-hidden="true">←</span>
        All producers
      </a>

      <div class="grid lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-5">
          <Photo src={photoByCommodity[p.commodity] || 'producerCoffee'} alt={p.photoCaption} aspect="4/5" loading="eager" />
        </div>

        <div class="lg:col-span-7 flex flex-col gap-6">
          <div class="flex items-baseline gap-3">
            <p class="eyebrow">{p.commodity} · {p.district}</p>
            {p.placeholder && <span class="text-[0.625rem] tracking-[0.18em] uppercase text-[var(--color-ink-muted)] border border-[var(--color-line)] px-2 py-0.5">Template profile</span>}
          </div>
          <h1 class="display-lg text-balance">{p.name}</h1>
          <p class="lede lede-wide">{p.summary}</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-20 lg:py-28">
    <Container>
      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-8">
        {[
          ['Region', p.region],
          ['Elevation', p.elevation],
          ['Farms', p.farms],
          ['Cooperative', p.cooperative ?? '—'],
        ].map(([k, v]) => (
          <div class="border-t border-[var(--color-line)] pt-5">
            <dt class="eyebrow eyebrow-muted mb-2">{k}</dt>
            <dd class="text-base leading-snug">{v}</dd>
          </div>
        ))}
      </dl>

      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-8 mt-12">
        <div class="border-t border-[var(--color-line)] pt-5">
          <p class="eyebrow eyebrow-muted mb-3">Varieties</p>
          <ul class="space-y-2">
            {p.varieties.map((v) => <li class="flex gap-3"><span class="text-[var(--color-clay)]">·</span>{v}</li>)}
          </ul>
        </div>
        <div class="border-t border-[var(--color-line)] pt-5">
          <p class="eyebrow eyebrow-muted mb-3">Processing</p>
          <ul class="space-y-2">
            {p.processing.map((v) => <li class="flex gap-3"><span class="text-[var(--color-clay)]">·</span>{v}</li>)}
          </ul>
        </div>
      </div>
    </Container>
  </section>

  {p.quote && (
    <section class="py-20 lg:py-28" style="background: var(--color-paper-warm);">
      <Container narrow>
        <blockquote>
          <p class="text-2xl lg:text-3xl leading-snug text-balance" style="font-family: var(--font-display); font-weight: 400;">
            "{p.quote}"
          </p>
          {p.quoteAttribution && <cite class="not-italic block mt-7 text-xs uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">— {p.quoteAttribution}</cite>}
        </blockquote>
      </Container>
    </section>
  )}

  <section class="py-20 lg:py-28">
    <Container narrow>
      <div class="body-editorial">
        <Content />
      </div>
      <a href="/producers" class="mt-14 inline-flex items-center gap-2 text-sm font-medium uppercase tracking-wider text-[var(--color-clay)]">
        <span aria-hidden="true">←</span>
        All producers
      </a>
    </Container>
  </section>
</BaseLayout>
