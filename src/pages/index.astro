---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityPhoto } from '~/lib/commodities';
import { photos } from '~/lib/photos';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Discovery Group — Ugandan coffee, cocoa, vanilla and spices" brand="discovery">

  {/* ═══════ HERO ═══════ */}
  <section class="section-hero w-full" style="background: var(--color-espresso);">
    <div class="absolute inset-0">
      <img src={photos.heroCorporate} alt="Coffee cherries at harvest in Uganda" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,11,8,0.45) 0%, rgba(15,11,8,0.1) 35%, rgba(15,11,8,0.8) 100%);"></div>
    </div>

    <Container class="relative pb-20 lg:pb-28">
      <p class="text-xs tracking-[0.22em] uppercase mb-6 font-medium" style="color: rgba(255,255,255,0.75);">
        Discovery Group · Kampala, Uganda
      </p>
      <h1 class="display-xxl text-balance" style="color: white; max-width: 16ch;">
        Ugandan coffee, cocoa, vanilla and spices, exported at origin.
      </h1>
      <p class="mt-7 max-w-xl text-lg leading-relaxed" style="color: rgba(255,255,255,0.82);">
        A vertically integrated agri-commodity exporter sourcing from
        cooperatives across Uganda and shipping to roasters, processors
        and distributors worldwide.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/products" class="btn btn-light">View our products</a>
        <a href="/contact" class="btn btn-ghost-light">Request samples</a>
      </div>
    </Container>
  </section>

  {/* ═══════ ABOUT ═══════ */}
  <section class="section-full">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-20 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow eyebrow-accent mb-6">About us</p>
          <h2 class="display-lg text-balance">
            A Ugandan exporter, operating at origin since 2014.
          </h2>
        </div>
        <div class="lg:col-span-7 flex flex-col gap-5 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          <p>
            Discovery Group sources, processes and ships agricultural
            commodities from across Uganda — coffee, cocoa, vanilla,
            sesame, bird's eye chilli, and beans and pulses. Our
            processing facility in Namanve Industrial Area handles every
            stage from receiving lots to stuffing containers for export.
          </p>
          <p>
            We work directly with farmer cooperatives, paying quality
            premiums against verified cup scores, cut tests and moisture
            readings. Every shipment leaves with full documentation,
            including geolocation files for EUDR-compliant consignments
            to the European Union.
          </p>
          <p>
            Our consumer brand, <a href="/orocafe">Orocafe</a>, roasts and
            packs single-origin Ugandan coffee at the same facility.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ═══════ PHOTO STRIP ═══════ */}
  <section class="section-full grid sm:grid-cols-2" style="padding: 0;">
    <Photo src="hands" alt="Hands selecting Arabica cherries during harvest" aspect="1/1" class="!aspect-auto h-full" />
    <Photo src="drying" alt="Coffee drying on raised beds at the cooperative" aspect="1/1" class="!aspect-auto h-full" />
  </section>

  {/* ═══════ CAPABILITIES ═══════ */}
  <section class="section-full" style="background: var(--color-paper-warm);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 mb-14 lg:mb-20 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow eyebrow-accent mb-5">What we do</p>
          <h2 class="display-lg text-balance">
            Four functions, one operation.
          </h2>
        </div>
        <p class="lg:col-span-5 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          Each stage is owned, audited and documented in-house — not
          subcontracted to third parties.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12">
        {[
          ['Sourcing', 'Direct relationships with farmer cooperatives across all major Ugandan growing regions. Polygon-level geolocation captured per lot.'],
          ['Processing', 'Dry-milling, fermentation, gravity-table sorting, optical sorting, conditioning and grade-building at our Namanve facility.'],
          ['Quality control', 'In-house Q-style cupping for coffee, cut tests for cocoa, moisture and vanillin testing for vanilla, capsaicin verification for chilli.'],
          ['Logistics', 'GrainPro-lined jute packaging, supervised FCL container stuffing, complete export documentation, FOB Mombasa or CIF on request.'],
        ].map(([title, body]) => (
          <article>
            <h3 class="text-xl mb-3" style="font-weight: 600; letter-spacing: -0.02em;">{title}</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{body}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  {/* ═══════ COMMODITIES — 3×2 grid that fits one screen ═══════ */}
  <section class="section-full">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 mb-10 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow eyebrow-accent mb-5">Our products</p>
          <h2 class="display-lg text-balance">Six commodity lines.</h2>
        </div>
        <p class="lg:col-span-5 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          Specifications, grades and indicative MOQs on each product page.
          Samples available on request.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        {commodities.map((c) => (
          <a href={`/products/${c.id}`} class="group block focus:outline-none">
            <Photo src={commodityPhoto[c.id] || 'coffee'} alt={c.data.title} aspect="4/5" class="transition-transform duration-500 group-hover:scale-[1.01]" />
            <div class="mt-5">
              <p class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] mb-2">{c.data.eyebrow}</p>
              <h3 class="h3 group-hover:text-[var(--color-clay)] transition-colors">{c.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  {/* ═══════ MAP / ORIGINS ═══════ */}
  <section class="section-full" style="background: var(--color-espresso); color: white;">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: var(--color-gold-light);">Origins</p>
          <h2 class="display-lg text-balance" style="color: white;">
            Sourced from six regions across Uganda.
          </h2>
          <p class="mt-7 text-[1.0625rem] leading-relaxed max-w-md" style="color: rgba(245,243,238,0.75);">
            From the volcanic slopes of Mt. Elgon and the Rwenzori, through
            the central belt, into West Nile, the northern lowlands and
            the southwestern highlands. Each commodity ships with its
            origin documented at cooperative level.
          </p>
          <a href="/producers" class="btn btn-ghost-light mt-10">Producer relationships</a>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto" style="color: white;" />
        </div>
      </div>
    </Container>
  </section>

  {/* ═══════ OROCAFE ═══════ */}
  <section class="section-full grid lg:grid-cols-2" style="background: var(--color-night); padding: 0;">
    <div class="relative h-full min-h-[50vh]">
      <img src={photos.heroOrocafe} alt="An espresso pour at the Orocafe roastery" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="flex flex-col justify-center px-6 lg:px-16 py-20 lg:py-0" style="color: white;">
      <p class="text-xs tracking-[0.22em] uppercase mb-6 font-medium" style="color: var(--color-oro);">Our consumer brand</p>
      <h2 class="display-lg text-balance" style="color: white;">
        Orocafe — Ugandan coffee, roasted at origin.
      </h2>
      <p class="mt-7 text-[1.0625rem] leading-relaxed max-w-md" style="color: rgba(245,239,226,0.78);">
        Single-origin Arabica from Mt. Elgon and Robusta from the
        Rwenzori, roasted and packed at our Namanve facility. Whole
        bean, ground, capsules, drip bags, premixes and instant teas
        for retail and food service.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/orocafe" class="btn btn-gold">Visit Orocafe</a>
        <a href="/orocafe/products" class="btn btn-ghost-light">View range</a>
      </div>
    </div>
  </section>

  {/* ═══════ SUSTAINABILITY ═══════ */}
  <section class="section-full">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <p class="eyebrow eyebrow-accent mb-5">Sustainability</p>
          <h2 class="display-lg text-balance">
            We invest in the cooperatives we source from.
          </h2>
          <p class="lede lede-wide mt-7">
            Premium payment against quality. Agronomy and post-harvest
            training. Documentation support for organic and Rainforest
            Alliance certification. Polygon geolocation for every
            EUDR-bound shipment.
          </p>

          <div class="mt-12 grid sm:grid-cols-3 gap-8">
            {[
              ['~900', 'Smallholder farmers in active programmes'],
              ['~50', 'Discovery employees across Namanve and origin'],
              ['100%', 'EUDR-bound lots with geolocation files'],
            ].map(([k, v]) => (
              <div>
                <p class="stat-number">{k}</p>
                <p class="mt-3 text-sm text-[var(--color-ink-muted)] leading-snug">{v}</p>
              </div>
            ))}
          </div>

          <a href="/sustainability" class="mt-12 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-clay)]">
            Read our sustainability approach →
          </a>
        </div>
        <div class="lg:col-span-5">
          <Photo src="cooperative" alt="Cooperative members at the season-planning gathering" aspect="4/5" />
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
