---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import PlaceholderPhoto from '~/components/PlaceholderPhoto.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import CommodityCard from '~/components/CommodityCard.astro';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Discovery Group — Ugandan coffee, cocoa, vanilla, sesame & spices, sourced at origin" brand="discovery">

  <!-- HERO -->
  <section class="relative">
    <Container class="pt-10 lg:pt-16">
      <div class="grid lg:grid-cols-12 gap-10 items-end">
        <div class="lg:col-span-7 flex flex-col gap-8">
          <p class="eyebrow">Operating at origin — Kampala, since 2014</p>
          <h1 class="display-xl text-balance">
            Uganda's commodities, <em class="not-italic" style="color: var(--color-clay);">from the soil they came out of.</em>
          </h1>
          <p class="lede">
            Discovery Group sources, processes, grades and ships Ugandan
            coffee, cocoa, vanilla, sesame, bird's eye chilli, beans and
            pulses — from cooperative-level buying right through to FCL
            container, on one floor at our Namanve facility.
          </p>
          <div class="flex flex-wrap gap-3 mt-2">
            <a href="/products" class="btn btn-primary">See our commodities</a>
            <a href="/contact" class="btn btn-secondary">Request samples</a>
          </div>
        </div>

        <div class="lg:col-span-5">
          <PlaceholderPhoto
            caption="Mt. Elgon Arabica cherry, morning of harvest"
            aspect="4/5"
            variant="clay"
          />
        </div>
      </div>
    </Container>
  </section>

  <!-- KEY STATS -->
  <section class="mt-24 lg:mt-32">
    <Container>
      <div class="border-t border-[var(--color-line)] grid sm:grid-cols-2 lg:grid-cols-4">
        {[
          ['2014', 'Founded — Discovery Trading Ltd, Kampala'],
          ['7', 'Commodity lines — coffee through pulses'],
          ['Namanve', 'In-house processing floor — buying to FCL'],
          ['EUDR', 'Ready, with geolocation files per lot'],
        ].map(([k, v]) => (
          <div class="border-b border-r-0 sm:border-r border-[var(--color-line)] last:border-r-0 px-6 py-8 lg:px-8 lg:py-10">
            <p class="font-display text-3xl lg:text-4xl tracking-tight" style="font-family: var(--font-display); font-weight: 600;">{k}</p>
            <p class="mt-3 text-sm text-[var(--color-ink-muted)] leading-relaxed">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CAPABILITIES NARRATIVE -->
  <section class="mt-24 lg:mt-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10">
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="What we do"
            title="From the buying centre to the container."
            lede="We are not brokers. Discovery operates the floor at Namanve where lots are received, cupped, graded, blended, sealed and stuffed for export."
          />
        </div>
        <div class="lg:col-span-7 grid sm:grid-cols-2 gap-x-10 gap-y-8">
          {[
            ['Direct sourcing', 'Cooperative-level buying with full geolocation per lot, including for EUDR-bound consignments.'],
            ['Processing at origin', 'Pulping, fermentation logs, drying, dry-milling, gravity table, optical sort, and conditioning — all in one location.'],
            ['Lot-built quality', 'Q-style cup analysis for coffee, cut-test grading for cocoa, vanillin and moisture testing for vanilla, capsaicin testing for chilli.'],
            ['Export logistics', 'GrainPro-lined jute, FCL stuffing under our supervision, full export documentation. FOB Mombasa standard; CIF on request.'],
          ].map(([k, v]) => (
            <div>
              <h3 class="font-display text-xl mb-2" style="font-family: var(--font-display); font-weight: 600;">{k}</h3>
              <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{v}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- COMMODITIES INDEX -->
  <section class="mt-24 lg:mt-32">
    <Container>
      <SectionHeading
        eyebrow="Commodities"
        title="Seven lines, one floor."
        lede="Each commodity has a dedicated processing path at Namanve and dedicated specs for export. Indicative MOQs and grades on the per-commodity pages."
      />
      <div class="mt-8">
        {commodities.map((c) => (
          <CommodityCard
            title={c.data.title}
            eyebrow={c.data.eyebrow}
            summary={c.data.summary}
            href={`/products/${c.id}`}
            regions={c.data.origin.regions}
            certifications={c.data.certifications}
            heroCaption={c.data.heroCaption}
            qualityMetricLabel={c.data.qualityMetricLabel}
            qualityMetricValue={c.data.qualityMetricValue}
          />
        ))}
      </div>
    </Container>
  </section>

  <!-- OROCAFE CROSS-LINK -->
  <section class="mt-24 lg:mt-32" style="background: var(--color-paper-deep);">
    <Container class="py-20 lg:py-28">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-6">
          <PlaceholderPhoto
            caption="Orocafe roasting floor at Namanve"
            aspect="3/2"
            variant="night"
          />
        </div>
        <div class="lg:col-span-6 flex flex-col gap-6">
          <p class="eyebrow">A Discovery Group brand</p>
          <h2 class="display-lg text-balance">
            Orocafe — when we don't ship the green, we roast it.
          </h2>
          <p class="lede">
            Single-origin Ugandan Arabica and Robusta, roasted and packed
            at Namanve. Whole bean, ground, Nespresso®-compatible
            capsules, drip bags, 3-in-1 premixes, and instant teas.
          </p>
          <div>
            <a href="/orocafe" class="btn btn-secondary">Visit Orocafe</a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- SUSTAINABILITY TEASER -->
  <section class="mt-24 lg:mt-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10">
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="Sustainability"
            title="Improving smallholder livelihoods is the business model."
            lede="Every lot we ship is traceable to a cooperative aggregation. Every cooperative is auditable. Every smallholder relationship is the supply we depend on."
          />
        </div>
        <div class="lg:col-span-7">
          <PlaceholderPhoto
            caption="Cooperative meeting, season planning round"
            aspect="16/9"
            variant="forest"
          />
          <a href="/sustainability" class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-clay)]">
            Our farmer impact and certifications
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
