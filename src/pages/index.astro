---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import CommodityCard from '~/components/CommodityCard.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityPhoto } from '~/lib/commodities';
import { photos } from '~/lib/photos';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Discovery Group — Ugandan coffee, cocoa, vanilla and spices" brand="discovery">

  {/* HERO — full-bleed image + overlay */}
  <section class="relative w-full" style="background: var(--color-espresso);">
    <div class="relative h-[88vh] min-h-[640px] max-h-[900px] w-full overflow-hidden">
      <img
        src={photos.heroCorporate}
        alt="Coffee cherries at harvest in Uganda"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,11,8,0.45) 0%, rgba(15,11,8,0.15) 35%, rgba(15,11,8,0.75) 100%);"></div>

      <Container class="relative h-full flex flex-col justify-end pb-20 lg:pb-28">
        <p class="text-xs tracking-[0.22em] uppercase mb-6" style="color: rgba(255,255,255,0.7);">
          Discovery Group · Kampala, Uganda
        </p>
        <h1 class="text-balance" style="font-family: var(--font-display); font-weight: 480; font-size: clamp(2.5rem, 6vw + 1rem, 5.5rem); line-height: 1.02; letter-spacing: -0.025em; color: white; max-width: 18ch;">
          Ugandan coffee, cocoa, vanilla and spices, exported at origin.
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-relaxed" style="color: rgba(255,255,255,0.8);">
          A vertically integrated agri-commodity exporter sourcing from
          cooperatives across Uganda and shipping to roasters, processors
          and distributors worldwide.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/products" class="btn btn-gold">View our products</a>
          <a href="/contact" class="btn btn-ghost-light">Request samples</a>
        </div>
      </Container>
    </div>
  </section>

  {/* INTRO */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-20 items-start">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-6">About us</p>
          <h2 class="display-lg text-balance">
            A Ugandan exporter, operated at origin since 2014.
          </h2>
        </div>
        <div class="lg:col-span-7 flex flex-col gap-5 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          <p>
            Discovery Group sources, processes and ships agricultural
            commodities from across Uganda — coffee, cocoa, vanilla,
            sesame, bird's eye chilli, and beans and pulses. Our
            processing facility in Namanve Industrial Area, just outside
            Kampala, handles every stage from receiving lots to stuffing
            containers for export.
          </p>
          <p>
            We work directly with cooperatives and smallholder farmers,
            paying quality premiums against verified cup scores, cut tests
            and moisture readings. Every shipment leaves with full
            documentation, including geolocation files for EUDR-compliant
            consignments to the European Union.
          </p>
          <p>
            Our consumer brand, <a href="/orocafe" class="underline underline-offset-4 hover:text-[var(--color-clay)]">Orocafe</a>,
            roasts and packs single-origin Ugandan coffee at the same
            facility — distributed to retail and food-service markets in
            East Africa and beyond.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* TWO-COLUMN PHOTO STRIP */}
  <section class="grid sm:grid-cols-2">
    <Photo src="hands" alt="Hands selecting Arabica cherries during harvest" aspect="4/5" loading="lazy" />
    <Photo src="drying" alt="Coffee drying on raised beds at the cooperative" aspect="4/5" loading="lazy" />
  </section>

  {/* CAPABILITIES */}
  <section class="py-24 lg:py-32" style="background: var(--color-paper-warm);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 mb-16 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">What we do</p>
          <h2 class="display-lg text-balance">
            Four functions, one operation.
          </h2>
        </div>
        <p class="lg:col-span-5 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          Each stage owned, audited and documented in-house — not
          subcontracted to third parties.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12">
        {[
          ['Sourcing', 'Direct relationships with farmer cooperatives across all major Ugandan growing regions. Polygon-level geolocation captured per lot.'],
          ['Processing', 'Dry-milling, fermentation, gravity table sorting, optical sorting, conditioning, and grade-building at our Namanve facility.'],
          ['Quality control', 'In-house Q-style cupping for coffee, cut tests for cocoa, moisture and vanillin testing for vanilla, capsaicin verification for chilli.'],
          ['Logistics', 'GrainPro-lined jute packaging, supervised FCL container stuffing, complete export documentation, FOB Mombasa or CIF on request.'],
        ].map(([title, body]) => (
          <article>
            <h3 class="font-display text-xl mb-3 tracking-tight" style="font-family: var(--font-display); font-weight: 540;">{title}</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{body}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  {/* COMMODITIES */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 mb-12 items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">Our products</p>
          <h2 class="display-lg text-balance">
            Six commodity lines.
          </h2>
        </div>
        <p class="lg:col-span-5 text-[1.0625rem] leading-relaxed text-[var(--color-ink-muted)]">
          Specifications, grades and indicative MOQs on each product page.
          Samples and lot documentation available on request.
        </p>
      </div>

      {commodities.map((c, i) => (
        <CommodityCard
          title={c.data.title}
          eyebrow={c.data.eyebrow}
          summary={c.data.summary}
          href={`/products/${c.id}`}
          regions={c.data.origin.regions}
          certifications={c.data.certifications}
          heroCaption={c.data.heroCaption}
          qualityMetricLabel={c.data.qualityMetricLabel}
          qualityMetricValue={c.data.qualityMetricValue}
          photo={commodityPhoto[c.id] || 'coffee'}
          index={i + 1}
        />
      ))}
    </Container>
  </section>

  {/* MAP / ORIGINS */}
  <section class="py-24 lg:py-32 relative" style="background: var(--color-espresso); color: var(--color-paper);">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: var(--color-gold-light);">Origins</p>
          <h2 class="display-lg text-balance" style="color: var(--color-paper);">
            Sourced from six regions across Uganda.
          </h2>
          <p class="mt-7 text-[1.0625rem] leading-relaxed max-w-md" style="color: rgba(242,235,219,0.75);">
            From the volcanic slopes of Mt. Elgon and the Rwenzori, through
            the central belt, into West Nile, the northern lowlands, and
            the southwestern highlands. Each commodity ships with its
            origin documented at cooperative level.
          </p>
          <a href="/producers" class="btn btn-ghost-light mt-10">
            Producer relationships
          </a>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto text-[var(--color-paper)]" />
        </div>
      </div>
    </Container>
  </section>

  {/* OROCAFE CROSS-LINK */}
  <section class="relative overflow-hidden" style="background: var(--color-night);">
    <div class="grid lg:grid-cols-12 min-h-[600px]">
      <div class="lg:col-span-6 relative">
        <Photo src="heroOrocafe" alt="Espresso shot pulled at the Orocafe roastery" aspect="3/2" class="h-full lg:absolute lg:inset-0" />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 lg:px-16 py-20 lg:py-24" style="color: var(--color-paper);">
        <p class="text-xs tracking-[0.22em] uppercase mb-6" style="color: var(--color-oro);">Our consumer brand</p>
        <h2 class="display-lg text-balance" style="color: var(--color-paper);">
          Orocafe — Ugandan coffee, roasted at origin.
        </h2>
        <p class="mt-7 text-[1.0625rem] leading-relaxed max-w-md" style="color: rgba(242,235,219,0.78);">
          Single-origin Arabica from Mt. Elgon and Robusta from the
          Rwenzori, roasted and packed at our Namanve facility. Whole
          bean, ground, capsules, drip bags, premixes and instant teas
          for retail and food-service.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a href="/orocafe" class="btn btn-gold">Visit Orocafe</a>
          <a href="/orocafe/products" class="btn btn-ghost-light">View range</a>
        </div>
      </div>
    </div>
  </section>

  {/* SUSTAINABILITY */}
  <section class="py-24 lg:py-32">
    <Container>
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">Sustainability</p>
          <h2 class="display-lg text-balance">
            We invest in the cooperatives we source from.
          </h2>
          <p class="lede lede-wide mt-7">
            Premium payment against quality. Agronomy and post-harvest
            training. Documentation support for organic and Rainforest
            Alliance certification. Polygon geolocation for every EUDR-bound
            shipment.
          </p>

          <div class="mt-12 grid sm:grid-cols-3 gap-8">
            {[
              ['~900', 'Smallholder farmers in active sourcing programmes'],
              ['~50', 'Discovery employees at Namanve and across origin'],
              ['100%', 'EUDR-bound lots with geolocation documentation'],
            ].map(([k, v]) => (
              <div>
                <p class="stat-number">{k}</p>
                <p class="mt-3 text-sm text-[var(--color-ink-muted)] leading-snug">{v}</p>
              </div>
            ))}
          </div>

          <a href="/sustainability" class="mt-12 inline-flex items-center gap-2 text-sm font-medium uppercase tracking-wider text-[var(--color-clay)]">
            Read our sustainability approach →
          </a>
        </div>
        <div class="lg:col-span-5">
          <Photo src="cooperative" alt="Cooperative members during the season-planning gathering" aspect="4/5" />
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
