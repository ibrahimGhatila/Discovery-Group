---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import HeroCarousel from '~/components/HeroCarousel.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityPhoto } from '~/lib/commodities';
import { photos } from '~/lib/photos';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Discovery Group — Sourcing, processing, exporting Ugandan agro-commodities" brand="discovery">

  {/* ═══ HERO ═══ */}
  <HeroCarousel />

  {/* ═══ WELCOME ═══ */}
  <section class="section-full">
    <div class="grid lg:grid-cols-2 gap-x-12 gap-y-8 items-center max-w-[var(--container-7xl)] mx-auto w-full px-6 lg:px-12">
      <div class="relative h-full max-h-[70vh]">
        <Photo src="warehouse" alt="Jute coffee bags at the Namanve facility" aspect="4/5" class="photo-hover h-full" />
      </div>
      <div class="reveal">
        <p class="eyebrow mb-5">Continually evolving in excellence</p>
        <h2 class="display-lg mb-6">Welcome to <br/>Discovery Group Ltd.</h2>
        <div class="body-editorial">
          <p>
            A leading agro-commodity exporter specialising in coffee, cocoa,
            vanilla, sesame and beans from Uganda. We handle every aspect
            of exporting — from sourcing the best products to processing,
            sorting and transporting them to the port of destination.
          </p>
          <p>
            With Orocafe (2022), we expanded into roasting and packaging
            finished coffee at origin.
          </p>
        </div>
        <a href="/about" class="link-arrow mt-8">About us</a>
      </div>
    </div>
  </section>

  {/* ═══ STATS — big and centered ═══ */}
  <section class="section-full" style="background: var(--color-paper-warm); border-block: 1px solid var(--color-line);">
    <Container>
      <div class="reveal text-center max-w-2xl mx-auto mb-10 lg:mb-14">
        <p class="eyebrow mb-5">A decade of origin-controlled trade</p>
        <h2 class="display-lg">By the numbers.</h2>
      </div>
      <div class="reveal-stagger grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-6">
        {[
          ['2014', 'Founded in Kampala'],
          ['7', 'Commodity lines'],
          ['900+', 'Smallholder partners'],
          ['100%', 'EUDR-compliant'],
        ].map(([k, v]) => (
          <div class="stat text-center">
            <p class="stat-number" style="font-size: clamp(3rem, 5vw + 1rem, 6rem);">{k}</p>
            <p class="stat-label">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* ═══ INTRODUCING OROCAFE — centered ═══ */}
  <section class="section-full">
    <Container>
      <div class="reveal max-w-2xl mx-auto text-center">
        <p class="eyebrow mb-6">From bean to bag · 100% made in Uganda</p>
        <h2 class="display-xl mb-8">Introducing Orocafe.</h2>
        <p class="mx-auto" style="text-align: center; line-height: 1.7; font-size: 1.0625rem; color: var(--color-ink-muted); max-width: 56ch;">
          Orocafe is dedicated to transforming the coffee industry in
          Uganda. We handle every step — sourcing to exporting — entirely
          at origin. Empowering local farmers and delivering superior
          coffee to the world.
        </p>
        <div class="mt-10">
          <a href="/orocafe" class="link-arrow">Discover Orocafe</a>
        </div>
      </div>
    </Container>
  </section>

  {/* ═══ PEARL OF AFRICA — dark forest feature ═══ */}
  <section class="section-full" style="background: var(--color-forest); color: white;">
    <div class="max-w-[var(--container-7xl)] mx-auto px-6 lg:px-12 w-full">
      <div class="grid lg:grid-cols-12 gap-x-10 gap-y-10 items-center">
        <div class="lg:col-span-5 reveal">
          <p class="eyebrow mb-5" style="color: var(--color-gold);">Why we have chosen Uganda</p>
          <h2 class="display-lg mb-6" style="color: white;">
            Looking for treasures in the Pearl of Africa.
          </h2>
          <div class="body-editorial">
            <p style="color: rgba(255,255,255,0.82);">
              The "Pearl of Africa" offers an exceptional combination of
              natural conditions — sunny climate, abundant rainfall,
              fertile volcanic soils, numerous rivers and lakes.
            </p>
            <p style="color: rgba(255,255,255,0.82);">
              The result is coffee with distinctive flavours and profiles —
              a prime origin for connoisseurs around the world.
            </p>
          </div>
          <a href="/about" class="btn btn-ghost-light mt-8">About us</a>
        </div>
        <div class="lg:col-span-3 reveal">
          <Photo src="warehouse" alt="Jute bag with green coffee" aspect="3/4" class="photo-hover" />
        </div>
        <div class="lg:col-span-4 reveal">
          <Photo src="producerCoffee" alt="Smallholder farmer in coffee plantation" aspect="4/5" class="photo-hover" />
        </div>
      </div>
    </div>
  </section>

  {/* ═══ PROCESSING AT SOURCE ═══ */}
  <section class="section-full">
    <div class="max-w-[var(--container-7xl)] mx-auto px-6 lg:px-12 w-full">
      <div class="grid lg:grid-cols-12 gap-x-10 gap-y-10 items-center">
        <div class="lg:col-span-3 reveal">
          <Photo src="roasting" alt="Coffee beans in a roasting drum" aspect="4/5" class="photo-hover" />
        </div>
        <div class="lg:col-span-4 reveal">
          <Photo src="espresso" alt="Orocafe packaging on roasted beans" aspect="4/5" class="photo-hover" />
        </div>
        <div class="lg:col-span-5 reveal lg:pl-6">
          <p class="eyebrow mb-5">A Discovery Group brand</p>
          <h2 class="display-lg mb-6">Processing at source.</h2>
          <div class="body-editorial">
            <p>
              Years of exposure to the African coffee industry compelled
              us to innovate — converting obstacles into opportunities
              for growth and sustainability.
            </p>
            <p>
              Orocafe sources, roasts and packs coffee directly at origin
              in Uganda — delivering exceptional products and fostering
              positive change at the source.
            </p>
          </div>
          <a href="/orocafe" class="link-arrow mt-8">Discover Orocafe</a>
        </div>
      </div>
    </div>
  </section>

  {/* ═══ SIX COMMODITY LINES — compact strip fitting one viewport ═══ */}
  <section class="section-full" style="background: var(--color-paper-warm);">
    <Container>
      <div class="reveal text-center max-w-2xl mx-auto mb-8 lg:mb-12">
        <p class="eyebrow mb-5">Our products</p>
        <h2 class="display-lg">Six Ugandan commodity lines.</h2>
      </div>

      <div class="reveal-stagger grid grid-cols-3 lg:grid-cols-6 gap-x-4 lg:gap-x-5 gap-y-6 lg:gap-y-8">
        {commodities.map((c) => (
          <a href={`/products/${c.id}`} class="group block focus:outline-none">
            <div class="photo-hover" style="aspect-ratio: 3/4;">
              <Photo src={commodityPhoto[c.id] || 'coffee'} alt={c.data.title} aspect="3/4" />
            </div>
            <div class="mt-3 lg:mt-4 text-center">
              <h3 class="text-base lg:text-lg uppercase tracking-wide group-hover:text-[var(--color-forest)] transition-colors" style="font-family: var(--font-display); font-weight: 400;">{c.data.title}</h3>
            </div>
          </a>
        ))}
      </div>

      <div class="reveal mt-10 lg:mt-12 text-center">
        <a href="/products" class="link-arrow">All products</a>
      </div>
    </Container>
  </section>

  {/* ═══ MAP ═══ */}
  <section class="section-full" style="background: var(--color-forest); color: white;">
    <Container>
      <div class="reveal grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: var(--color-gold);">Origins</p>
          <h2 class="display-lg mb-6" style="color: white;">Sourced across six Ugandan regions.</h2>
          <p class="lede" style="color: rgba(255,255,255,0.78);">
            Mt. Elgon · Rwenzori · Lake Victoria crescent · West Nile ·
            Northern belt · Southwestern highlands.
          </p>
          <a href="/producers" class="btn btn-ghost-light mt-10">Our producers</a>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto max-h-[60vh]" style="color: white;" />
        </div>
      </div>
    </Container>
  </section>

  {/* ═══ CONTACT CTA ═══ */}
  <section class="section-full">
    <Container>
      <div class="reveal text-center max-w-3xl mx-auto">
        <p class="eyebrow mb-7">Get in touch</p>
        <h2 class="display-xl mb-8">Let's start a conversation.</h2>
        <p class="lede mx-auto">
          Tell us what commodity, volume and destination — we'll come
          back with samples and pricing.
        </p>
        <div class="mt-10 flex flex-wrap gap-3 justify-center">
          <a href="/contact" class="btn btn-primary">Send inquiry</a>
          <a href="mailto:info@discoverygroupug.com" class="btn btn-secondary">info@discoverygroupug.com</a>
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
