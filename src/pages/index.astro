---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import HeroCarousel from '~/components/HeroCarousel.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityPhoto } from '~/lib/commodities';
import { photos } from '~/lib/photos';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Discovery Group — Ugandan coffee, cocoa, vanilla and spices" brand="discovery">

  {/* HERO */}
  <HeroCarousel />

  {/* AT A GLANCE — numbers only, no body copy */}
  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal max-w-2xl mb-14 lg:mb-20">
        <p class="eyebrow mb-5">At a glance</p>
        <h2 class="display-lg text-balance">A decade of origin-controlled trade.</h2>
      </div>

      <div class="reveal-stagger grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 border-t border-[var(--color-line)] pt-12">
        {[
          ['2014', 'Founded'],
          ['7', 'Commodity lines'],
          ['900+', 'Smallholder partners'],
          ['100%', 'EUDR-compliant'],
        ].map(([k, v]) => (
          <div class="stat">
            <p class="stat-number">{k}</p>
            <p class="stat-label">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* PRODUCTS — photo + name only */}
  <section class="section">
    <Container>
      <div class="reveal flex items-end justify-between flex-wrap gap-6 mb-12 lg:mb-16">
        <div>
          <p class="eyebrow mb-5">Products</p>
          <h2 class="display-lg text-balance">Six commodity lines.</h2>
        </div>
        <a href="/products" class="link-arrow">All products</a>
      </div>

      <div class="reveal-stagger grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 lg:gap-x-8 gap-y-12">
        {commodities.map((c) => (
          <a href={`/products/${c.id}`} class="skim-card group focus:outline-none">
            <div class="photo-hover">
              <Photo src={commodityPhoto[c.id] || 'coffee'} alt={c.data.title} aspect="4/5" />
            </div>
            <div class="skim-card-body">
              <p class="skim-card-name">{c.data.title}</p>
              <div class="skim-card-name-meta">
                <span class="skim-card-meta">{c.data.eyebrow.split(' · ')[0]}</span>
                <span class="skim-card-meta text-[var(--color-clay)] opacity-0 group-hover:opacity-100 transition-opacity">View →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  {/* MAP — minimal copy */}
  <section class="section" style="background: var(--color-espresso); color: white;">
    <Container>
      <div class="reveal grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-5" style="color: rgba(255,255,255,0.6);">Origins</p>
          <h2 class="display-lg text-balance" style="color: white;">
            Sourced from six Ugandan regions.
          </h2>
          <p class="lede mt-6" style="color: rgba(255,255,255,0.7);">
            Mt. Elgon. Rwenzori. Lake Victoria crescent. West Nile. Northern belt. Southwestern highlands.
          </p>
          <a href="/producers" class="mt-10 inline-flex items-center gap-2 text-sm font-medium" style="color: white; border-bottom: 1px solid rgba(255,255,255,0.4); padding-bottom: 4px;">
            Our producers
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto" style="color: white;" />
        </div>
      </div>
    </Container>
  </section>

  {/* CAPABILITIES — terse */}
  <section class="section">
    <Container>
      <div class="reveal mb-14 lg:mb-16">
        <p class="eyebrow mb-5">Capabilities</p>
        <h2 class="display-lg text-balance">Four functions. One operation.</h2>
      </div>

      <div class="reveal-stagger grid sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12 border-t border-[var(--color-line)] pt-12">
        {[
          ['01', 'Sourcing', 'Direct from cooperatives.'],
          ['02', 'Processing', 'Dry-mill, sort, grade.'],
          ['03', 'Quality', 'Cupped and tested.'],
          ['04', 'Logistics', 'FOB to your port.'],
        ].map(([num, title, body]) => (
          <div class="flex flex-col gap-3">
            <span class="font-mono text-xs text-[var(--color-clay)]">{num}</span>
            <h3 class="h3">{title}</h3>
            <p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">{body}</p>
          </div>
        ))}
      </div>

      <div class="reveal mt-12">
        <a href="/about" class="link-arrow">How we operate</a>
      </div>
    </Container>
  </section>

  {/* OROCAFE — split image + minimal text */}
  <section class="grid lg:grid-cols-2 min-h-[80vh]" style="background: var(--color-night);">
    <div class="relative photo-hover min-h-[40vh]">
      <img src={photos.espresso} alt="Espresso pour at the Orocafe roastery" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="reveal flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-20 lg:py-24" style="color: white;">
      <p class="hero-eyebrow" style="margin-bottom: 1.75rem;">
        <span class="hero-eyebrow-rule" style="background: var(--color-oro);"></span>
        A Discovery Group brand
      </p>
      <h2 class="display-lg text-balance" style="color: white;">
        Orocafe — coffee roasted in Kampala.
      </h2>
      <p class="lede mt-6" style="color: rgba(255,255,255,0.75);">
        Single-origin Ugandan Arabica and Robusta, packed at our facility.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/orocafe" class="btn btn-gold">Visit Orocafe</a>
        <a href="/orocafe/products" class="btn btn-ghost-light">Range</a>
      </div>
    </div>
  </section>

  {/* CERTIFICATIONS — compact strip, photo-led */}
  <section class="section" style="background: var(--color-paper-pure);">
    <Container>
      <div class="reveal mb-12">
        <p class="eyebrow mb-5">Certifications</p>
        <h2 class="display-lg text-balance">Audited, attached to the lot.</h2>
      </div>
      <div class="reveal-stagger grid grid-cols-3 lg:grid-cols-6 gap-px border border-[var(--color-line)]">
        {['Organic', 'Rainforest Alliance', 'Fairtrade', 'Halal', 'EUDR', 'UCDA'].map((c) => (
          <div class="px-6 py-10 flex items-center justify-center text-center bg-[var(--color-paper-pure)]">
            <p class="text-xs font-medium uppercase tracking-[0.14em] text-[var(--color-ink-muted)]">{c}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* CONTACT */}
  <section class="section" style="background: var(--color-paper-warm);">
    <Container>
      <div class="reveal max-w-3xl">
        <p class="eyebrow mb-5">Get in touch</p>
        <h2 class="display-xl text-balance">
          Tell us what you need — we'll come back with samples and pricing.
        </h2>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Send inquiry</a>
          <a href="mailto:info@discoverygroupug.com" class="btn btn-secondary">info@discoverygroupug.com</a>
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
