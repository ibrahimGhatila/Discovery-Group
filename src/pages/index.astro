---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
import Photo from '~/components/Photo.astro';
import HeroCarousel from '~/components/HeroCarousel.astro';
import UgandaMap from '~/components/illus/UgandaMap.astro';
import { commodityPhoto } from '~/lib/commodities';
import { photos } from '~/lib/photos';
import { getCollection } from 'astro:content';

const commodities = (await getCollection('commodities')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Discovery Group — Sourcing, processing, exporting Ugandan agro-commodities" brand="discovery">

  {/* ═══ HERO ═══ */}
  <HeroCarousel />

  {/* ═══ WELCOME ═══ */}
  <section class="section">
    <div class="grid lg:grid-cols-2 gap-x-12 gap-y-12 items-center max-w-[var(--container-7xl)] mx-auto">
      <div class="relative">
        <Photo src="warehouse" alt="Jute coffee bags at the Namanve facility" aspect="4/5" class="photo-hover" />
      </div>
      <div class="px-6 lg:px-8 reveal">
        <p class="eyebrow mb-6">Continually evolving in excellence</p>
        <h2 class="display-xl mb-8">Welcome to <br/>Discovery Group Ltd.</h2>
        <div class="body-editorial">
          <p>
            Discovery Group is a leading agro-commodity exporter
            specialising in coffee, cocoa, vanilla, sesame, beans and other
            agricultural crops from Uganda. We handle every aspect of
            exporting — from sourcing the best products to processing,
            sorting, selecting and transporting them to the port of
            destination.
          </p>
          <p>
            With the launch of our Orocafe brand in 2022, we expanded
            our operations to include roasting, packaging and selling
            finished coffee products in the country of origin.
          </p>
        </div>
        <a href="/about" class="link-arrow mt-10">About us</a>
      </div>
    </div>
  </section>

  {/* ═══ STATS ═══ */}
  <section class="section-tight" style="background: var(--color-paper-warm); border-block: 1px solid var(--color-line);">
    <Container>
      <div class="reveal-stagger grid grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-6">
        {[
          ['2014', 'Founded in Kampala'],
          ['7', 'Commodity lines'],
          ['900+', 'Smallholder partners'],
          ['100%', 'EUDR-compliant'],
        ].map(([k, v]) => (
          <div class="stat">
            <p class="stat-number">{k}</p>
            <p class="stat-label">{v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* ═══ INTRODUCING OROCAFE — centered ═══ */}
  <section class="section">
    <Container>
      <div class="reveal max-w-2xl mx-auto text-center">
        <p class="eyebrow mb-7">From bean to bag · 100% made in Uganda</p>
        <h2 class="display-xl mb-8">Introducing Orocafe</h2>
        <p class="body-editorial mx-auto" style="text-align: center;">
          <p class="mx-auto" style="text-align: center; line-height: 1.7; font-size: 1rem; color: var(--color-ink-muted); max-width: 56ch;">
            Orocafe is dedicated to transforming the coffee industry in
            Uganda. Our mission is to showcase the exceptional quality of
            African coffee by handling every step — from sourcing to
            exporting — entirely at origin. We empower local farmers,
            boost the Ugandan economy, and deliver superior coffee to
            the world.
          </p>
        </p>
        <a href="/orocafe" class="link-arrow mt-10">Discover Orocafe</a>
      </div>
    </Container>
  </section>

  {/* ═══ PEARL OF AFRICA — dark forest feature ═══ */}
  <section class="section" style="background: var(--color-forest); color: white;">
    <div class="max-w-[var(--container-7xl)] mx-auto px-6 lg:px-12">
      <div class="grid lg:grid-cols-12 gap-x-10 gap-y-14 items-center">

        <div class="lg:col-span-5 reveal">
          <h2 class="display-lg mb-8" style="color: white;">
            Looking for treasures in the Pearl of Africa.
          </h2>
          <p class="eyebrow mb-6" style="color: var(--color-gold);">Why we have chosen Uganda</p>
          <div class="body-editorial">
            <p style="color: rgba(255,255,255,0.82);">
              Africa is a continent rich in agricultural potential, and
              Uganda stands out. Often called the "Pearl of Africa,"
              Uganda offers an exceptional combination of natural
              conditions for farming — sunny mild climate, regular
              abundant rainfall, fertile volcanic soils, numerous rivers
              and lakes.
            </p>
            <p style="color: rgba(255,255,255,0.82);">
              This produces coffee with distinctive flavours and profiles
              — a prime origin for connoisseurs around the world.
            </p>
          </div>
          <a href="/about" class="btn btn-ghost-light mt-10">About us</a>
        </div>

        <div class="lg:col-span-3 reveal">
          <Photo src="warehouse" alt="Jute bag with green coffee sample being drawn" aspect="3/4" class="photo-hover" />
        </div>

        <div class="lg:col-span-4 reveal">
          <Photo src="producerCoffee" alt="Smallholder farmer in his coffee plantation" aspect="4/5" class="photo-hover" />
        </div>
      </div>
    </div>
  </section>

  {/* ═══ PROCESSING AT SOURCE ═══ */}
  <section class="section">
    <div class="max-w-[var(--container-7xl)] mx-auto px-6 lg:px-12">
      <div class="grid lg:grid-cols-12 gap-x-10 gap-y-14 items-center">

        <div class="lg:col-span-3 reveal">
          <Photo src="roasting" alt="Coffee beans in a roasting drum" aspect="4/5" class="photo-hover" />
        </div>

        <div class="lg:col-span-4 reveal">
          <Photo src="espresso" alt="Orocafe Specialty Blend packaging on roasted beans" aspect="4/5" class="photo-hover" />
        </div>

        <div class="lg:col-span-5 reveal lg:pl-6">
          <p class="eyebrow mb-6">A Discovery Group brand</p>
          <h2 class="display-lg mb-8">Processing at source.</h2>
          <div class="body-editorial">
            <p>
              Years of working in the agro-commodity sector exposed us to
              the challenges of the African coffee industry. Those
              challenges compelled us to innovate — converting obstacles
              into opportunities for growth and sustainability.
            </p>
            <p>
              Orocafe sources, roasts and packs coffee directly at origin
              in Uganda. The approach delivers exceptional products and
              fosters positive change at the source.
            </p>
          </div>
          <a href="/orocafe" class="link-arrow mt-10">Discover Orocafe</a>
        </div>
      </div>
    </div>
  </section>

  {/* ═══ COMMODITY LINES ═══ */}
  <section class="section" style="background: var(--color-paper-warm);">
    <Container>
      <div class="reveal text-center max-w-2xl mx-auto mb-14 lg:mb-20">
        <p class="eyebrow mb-6">Our products</p>
        <h2 class="display-xl">Six Ugandan commodity lines.</h2>
      </div>

      <div class="reveal-stagger grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 lg:gap-x-8 gap-y-12">
        {commodities.map((c) => (
          <a href={`/products/${c.id}`} class="group block focus:outline-none">
            <div class="photo-hover">
              <Photo src={commodityPhoto[c.id] || 'coffee'} alt={c.data.title} aspect="4/5" />
            </div>
            <div class="mt-5 flex items-baseline justify-between gap-3">
              <h3 class="h2 group-hover:text-[var(--color-forest)] transition-colors">{c.data.title}</h3>
              <span class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-muted)] opacity-0 group-hover:opacity-100 transition-opacity">View →</span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  {/* ═══ MAP ═══ */}
  <section class="section" style="background: var(--color-forest); color: white;">
    <Container>
      <div class="reveal grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-6" style="color: var(--color-gold);">Origins</p>
          <h2 class="display-lg mb-8" style="color: white;">Sourced across six Ugandan regions.</h2>
          <p class="lede" style="color: rgba(255,255,255,0.75);">
            Mt. Elgon · Rwenzori · Lake Victoria crescent · West Nile ·
            Northern belt · Southwestern highlands.
          </p>
          <a href="/producers" class="btn btn-ghost-light mt-10">Our producers</a>
        </div>
        <div class="lg:col-span-7">
          <UgandaMap class="w-full h-auto" style="color: white;" />
        </div>
      </div>
    </Container>
  </section>

  {/* ═══ CONTACT CTA ═══ */}
  <section class="section">
    <Container>
      <div class="reveal text-center max-w-3xl mx-auto">
        <p class="eyebrow mb-7">Get in touch</p>
        <h2 class="display-xl mb-8">Let's start a conversation.</h2>
        <p class="lede mx-auto">
          Tell us what commodity, volume and destination — we'll come
          back with samples and pricing.
        </p>
        <div class="mt-10 flex flex-wrap gap-3 justify-center">
          <a href="/contact" class="btn btn-primary">Send inquiry</a>
          <a href="mailto:info@discoverygroupug.com" class="btn btn-secondary">info@discoverygroupug.com</a>
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
