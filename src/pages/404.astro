---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
---
<BaseLayout title="Not found — Discovery Group" description="The page you were looking for could not be found.">
  <section class="pt-20 lg:pt-32 pb-32">
    <Container narrow>
      <p class="eyebrow mb-4">404</p>
      <h1 class="display-lg text-balance">This page took a different route to port.</h1>
      <p class="lede mt-5">Try one of these instead.</p>
      <ul class="mt-8 grid sm:grid-cols-2 gap-3 max-w-md">
        <li><a class="block border border-[var(--color-line)] px-4 py-3 hover:bg-[var(--color-paper-deep)]" href="/products">Products</a></li>
        <li><a class="block border border-[var(--color-line)] px-4 py-3 hover:bg-[var(--color-paper-deep)]" href="/orocafe">Orocafe</a></li>
        <li><a class="block border border-[var(--color-line)] px-4 py-3 hover:bg-[var(--color-paper-deep)]" href="/sustainability">Sustainability</a></li>
        <li><a class="block border border-[var(--color-line)] px-4 py-3 hover:bg-[var(--color-paper-deep)]" href="/contact">Contact</a></li>
      </ul>
    </Container>
  </section>
</BaseLayout>
