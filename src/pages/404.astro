---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/Container.astro';
---
<BaseLayout title="Not found — Discovery Group" description="The page you were looking for could not be found.">
  <section class="py-32 lg:py-44">
    <Container narrow>
      <p class="eyebrow mb-6">№ 404</p>
      <h1 class="display-xl text-balance">
        This page took <span class="italic-soft" style="color: var(--color-clay); font-weight: 380;">a different route to port.</span>
      </h1>
      <p class="lede lede-wide mt-8">Try one of these instead.</p>
      <ul class="mt-10 grid sm:grid-cols-2 gap-3 max-w-md">
        <li><a class="block border border-[var(--color-line)] px-5 py-4 hover:bg-[var(--color-paper-warm)] hover:border-[var(--color-clay)]" href="/products">Products</a></li>
        <li><a class="block border border-[var(--color-line)] px-5 py-4 hover:bg-[var(--color-paper-warm)] hover:border-[var(--color-clay)]" href="/orocafe">Orocafe</a></li>
        <li><a class="block border border-[var(--color-line)] px-5 py-4 hover:bg-[var(--color-paper-warm)] hover:border-[var(--color-clay)]" href="/sustainability">Sustainability</a></li>
        <li><a class="block border border-[var(--color-line)] px-5 py-4 hover:bg-[var(--color-paper-warm)] hover:border-[var(--color-clay)]" href="/contact">Contact</a></li>
      </ul>
    </Container>
  </section>
</BaseLayout>
